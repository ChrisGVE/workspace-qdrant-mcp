# Git
.git/
.gitignore

# Rust build artifacts — top-level and per-crate target dirs
src/rust/target/
src/rust/**/target/
src/rust/**/*.d

# Node.js dependencies (rebuilt in Docker)
src/typescript/mcp-server/node_modules/
src/typescript/mcp-server/dist/

# Old Docker folder
docker/*
!docker/memexd-entrypoint.sh
!docker/jdtls-wrapper.sh

# TaskMaster and Claude config
.taskmaster/
.claude/

# Temporary files
tmp/

# Documentation and research (not needed for build)
docs/
research/

# Test files
src/typescript/mcp-server/src/**/*.test.ts
src/typescript/mcp-server/src/**/*.spec.ts

# OS artifacts
.DS_Store
Thumbs.db

# Runtime data — never part of the build context
state/
logs/

# ML model cache (downloaded at runtime, not part of build)
.fastembed_cache/

# Fork/branch tracking state
.wqm-fork/

# GitHub Actions / CI configs
.github/

# Markdown docs (not needed inside the image)
*.md
!src/**/*.md

# Install/deploy scripts (runtime only)
install.sh
install.ps1
docker-up.ps1

# Package manager / distribution configs
Formula/
manifests/
smithery.yaml
sentinel-config.yaml

# Pre-commit / linting configs
.pre-commit-config.yaml
.gitleaks.toml
