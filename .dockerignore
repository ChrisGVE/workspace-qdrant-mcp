# Git
.git/
.gitignore

# Rust build artifacts — top-level and per-crate target dirs
src/rust/target/
src/rust/**/target/
src/rust/**/*.d

# Docker support files: exclude everything except entrypoint scripts
# Dockerfile.memexd (built from repo root via CI) copies
# docker/memexd-entrypoint.sh into the image (line 289), so the docker/
# tree must NOT be excluded wholesale.  Exclude only the sub-trees that
# are never needed inside a build context.
docker/compose/
docker/docs/
docker/grafana/
docker/integration-tests/
docker/k8s/
docker/nginx/
docker/caddy/
docker/otel/
docker/prometheus/
docker/tests/

# TaskMaster and Claude config
.taskmaster/
.claude/

# Temporary files
tmp/

# Documentation and research (not needed for build)
docs/
research/

# OS artifacts
.DS_Store
Thumbs.db
