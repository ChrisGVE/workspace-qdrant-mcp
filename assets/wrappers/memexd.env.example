# memexd environment file template.
#
# Install:
#   mkdir -p ~/.config/memexd
#   cp assets/wrappers/memexd.env.example ~/.config/memexd/env
#   chmod 600 ~/.config/memexd/env
#   $EDITOR ~/.config/memexd/env  # paste real values
#
# The wrapper script `memexd-launch` will refuse to source this file if
# its permissions are anything other than 0600 or 0400. Keep it out of
# version control and out of any backup that mirrors permissions loosely.

# Required when embedding.provider = openai_compatible
OPENAI_API_KEY=

# Optional: Qdrant Cloud
# QDRANT_API_KEY=

# Optional: alternative provider key env var (must match
# embedding.api_key_env_var in the daemon config)
# AZURE_OPENAI_API_KEY=
