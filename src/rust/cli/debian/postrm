#!/bin/sh
# Post-remove script for wqm-cli.
#
# Reload systemd so the memexd.service unit disappears from
# `systemctl list-unit-files` output. We do NOT remove user data
# (state files under /var/lib/workspace-qdrant or
# ~/.workspace-qdrant) — that is the user's prerogative.

set -e

case "$1" in
    remove|purge|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        ;;
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0
