[
  {
    "name": "empty_object",
    "value": {},
    "expected": "{}"
  },
  {
    "name": "empty_array",
    "value": [],
    "expected": "[]"
  },
  {
    "name": "null",
    "value": null,
    "expected": "null"
  },
  {
    "name": "bool_true",
    "value": true,
    "expected": "true"
  },
  {
    "name": "bool_false",
    "value": false,
    "expected": "false"
  },
  {
    "name": "int",
    "value": 42,
    "expected": "42"
  },
  {
    "name": "negative_int",
    "value": -7,
    "expected": "-7"
  },
  {
    "name": "zero",
    "value": 0,
    "expected": "0"
  },
  {
    "name": "float",
    "value": 3.14,
    "expected": "3.14"
  },
  {
    "name": "string_simple",
    "value": "hello",
    "expected": "\"hello\""
  },
  {
    "name": "string_empty",
    "value": "",
    "expected": "\"\""
  },
  {
    "name": "string_quotes",
    "value": "he said \"hi\"",
    "expected": "\"he said \\\"hi\\\"\""
  },
  {
    "name": "string_backslash",
    "value": "a\\b",
    "expected": "\"a\\\\b\""
  },
  {
    "name": "string_newline",
    "value": "line1\nline2",
    "expected": "\"line1\\nline2\""
  },
  {
    "name": "string_tab",
    "value": "a\tb",
    "expected": "\"a\\tb\""
  },
  {
    "name": "string_unicode",
    "value": "café ☕ 日本語",
    "expected": "\"café ☕ 日本語\""
  },
  {
    "name": "string_emoji_surrogate",
    "value": "👍🏽 end",
    "expected": "\"👍🏽 end\""
  },
  {
    "name": "keys_unsorted",
    "value": {
      "b": 1,
      "a": 2,
      "c": 3
    },
    "expected": "{\"a\":2,\"b\":1,\"c\":3}"
  },
  {
    "name": "keys_caps_vs_lower",
    "value": {
      "Z": 1,
      "a": 2,
      "B": 3
    },
    "expected": "{\"B\":3,\"Z\":1,\"a\":2}"
  },
  {
    "name": "keys_numeric_strings",
    "value": {
      "1": 3,
      "2": 2,
      "10": 1
    },
    "expected": "{\"1\":3,\"10\":1,\"2\":2}"
  },
  {
    "name": "keys_unicode",
    "value": {
      "é": 1,
      "a": 2,
      "z": 3
    },
    "expected": "{\"a\":2,\"z\":3,\"é\":1}"
  },
  {
    "name": "nested_object",
    "value": {
      "outer": {
        "z": 1,
        "a": 2
      },
      "first": {
        "y": 3,
        "b": 4
      }
    },
    "expected": "{\"first\":{\"b\":4,\"y\":3},\"outer\":{\"a\":2,\"z\":1}}"
  },
  {
    "name": "array_of_objects",
    "value": [
      {
        "b": 1,
        "a": 2
      },
      {
        "d": 3,
        "c": 4
      }
    ],
    "expected": "[{\"a\":2,\"b\":1},{\"c\":4,\"d\":3}]"
  },
  {
    "name": "array_mixed",
    "value": [
      1,
      "two",
      true,
      null,
      {
        "k": "v"
      }
    ],
    "expected": "[1,\"two\",true,null,{\"k\":\"v\"}]"
  },
  {
    "name": "deep_nesting",
    "value": {
      "a": {
        "b": {
          "c": {
            "d": [
              1,
              {
                "e": 2
              }
            ]
          }
        }
      }
    },
    "expected": "{\"a\":{\"b\":{\"c\":{\"d\":[1,{\"e\":2}]}}}}"
  },
  {
    "name": "value_with_null_field",
    "value": {
      "a": null,
      "b": 1
    },
    "expected": "{\"a\":null,\"b\":1}"
  },
  {
    "name": "value_with_empty_nested",
    "value": {
      "a": {},
      "b": [],
      "c": 0
    },
    "expected": "{\"a\":{},\"b\":[],\"c\":0}"
  },
  {
    "name": "large_int",
    "value": 9007199254740991,
    "expected": "9007199254740991"
  },
  {
    "name": "string_slash",
    "value": "a/b/c",
    "expected": "\"a/b/c\""
  },
  {
    "name": "string_control",
    "value": "a\u0001b",
    "expected": "\"a\\u0001b\""
  },
  {
    "name": "keys_with_spaces",
    "value": {
      "b key": 1,
      "a key": 2
    },
    "expected": "{\"a key\":2,\"b key\":1}"
  },
  {
    "name": "unicode_key_sort",
    "value": {
      "0": 4,
      "Z": 1,
      "a": 2,
      "é": 3
    },
    "expected": "{\"0\":4,\"Z\":1,\"a\":2,\"é\":3}"
  }
]
