# Makefile.win - operacoes Windows para o fork do workspace-qdrant-mcp.
#
# Requer GNU Make e PowerShell. Use:
#   make -f Makefile.win doctor
#
# Variaveis uteis:
#   REPO=C:\dev\workspace-qdrant-mcp
#   PROJECT=C:\dev\meu-projeto
#   BRANCH=personal/windows-hardening
#   SERVER_NAME=workspace-qdrant
#   QDRANT_URL=http://localhost:6333
#   DAEMON_ENDPOINT=http://localhost:50051
#   FASTEMBED_DAEMON_ENDPOINT=http://localhost:55151
#   TOOLS=search,retrieve,grep,list,store,rules
#   MCP_HTTP_PORT=6335
#   LOG_DIR=C:\dev\workspace-qdrant-mcp\.wqm-fork\logs
#
# Fluxo de branches (desde 2026-05-29):
#   upstream/main --(ff)--> upstream-sync --(merge)--> dev --(promote quando estavel)--> main
#   main = versao estavel | dev = trabalho (com CI) | upstream-sync = espelho fetch-only
# Targets: sync-upstream, sync-dev, promote, fix-start, fix-promote, branch-status. Veja AGENTS.md.
#
# Politica: a main so recebe promocoes estaveis (promote); upstream e fetch-only (push desabilitado).

SHELL := powershell.exe
.SHELLFLAGS := -NoProfile -ExecutionPolicy Bypass -Command

REPO ?= $(CURDIR)
PROJECT ?= $(CURDIR)
BRANCH ?= personal/windows-hardening
SERVER_NAME ?= workspace-qdrant
COMPOSE_FILE ?= $(REPO)\docker-compose.yml
COMPOSE_ENV_FILE ?= $(REPO)\docker\.env
QDRANT_HTTP_PORT ?= 6333
QDRANT_GRPC_PORT ?= 6334
MCP_HTTP_PORT ?= 6335
QDRANT_URL ?= http://localhost:$(QDRANT_HTTP_PORT)
DAEMON_ENDPOINT ?= http://localhost:50051
# TOOLS list lives in src/typescript/mcp-server/src/constants/mcp-public-config.json.
# Override here only for ad-hoc experiments; otherwise leave unset so gen-mcp-config.ps1
# reads from the JSON (single source of truth, verified by config-drift.test.ts).
TOOLS ?= (default)
LOG_DIR ?= $(REPO)\.wqm-fork\logs
OBS_INTERVAL ?= 30

MCP_HEALTH_URL ?= http://localhost:$(MCP_HTTP_PORT)/admin/api/health
MCP_INIT_URL ?= http://localhost:$(MCP_HTTP_PORT)/admin/init

UPSTREAM_URL ?= https://github.com/ChrisGVE/workspace-qdrant-mcp.git
MAIN_BRANCH ?= main
DEV_BRANCH ?= dev
UPSTREAM_SYNC_BRANCH ?= upstream-sync
FIX_BRANCH ?= fix/rules-tenant-scope
SYNC_STRATEGY ?= merge
PUSH ?= false
TAG ?= fork-claude-codex-ready-v0.1.0
TENANT_PATCH ?= patches/fixes/fix-rules-tenant-scope.patch
TENANT_HARDEN_PATCH ?= patches/fixes/harden-rules-add-scope-error.patch

REGISTRY ?= $(REPO)\.wqm-fork\projects.json
WORKSPACE_NAME ?= workspace-qdrant
WORKSPACE_PROJECT ?= $(PROJECT)
WORKSPACE_FIX_BRANCH ?= $(FIX_BRANCH)
MCP_MANAGER_PATCH ?= patches/mcp/fork-workspace-mcp-tool.patch

# Registry do fork e registry dos projetos indexados sao diferentes.
FORK_REGISTRY ?= $(REPO)\.wqm-fork\fork-branches.json
INDEX_REGISTRY ?= $(REPO)\.wqm-fork\indexed-projects.json
INDEX_PROJECT_NAME ?= $(WORKSPACE_NAME)
INDEX_PROJECT ?= $(PROJECT)
INDEX_BRANCH ?= agent/wqm-change
INDEX_BASE_BRANCH ?= main
INDEX_RETURN_BRANCH ?= $(INDEX_BASE_BRANCH)
INDEX_WORKTREE_PATH ?=
INDEX_WORKTREE_ROOT ?=
INDEX_USE_WORKTREE ?= true
INDEX_PURPOSE ?= agent change
INDEX_CREATED_BY ?= ai-agent
INDEX_MUTATE ?= true
WORKSPACE_INDEX_PATCH ?= patches/mcp/workspace-index-mcp-tool.patch
FASTEMBED_CACHE_DIR ?= $(REPO)\.fastembed_cache
FASTEMBED_QDRANT_URL ?= http://127.0.0.1:$(QDRANT_GRPC_PORT)
FASTEMBED_GRPC_PORT ?= 55151
FASTEMBED_CONTROL_PORT ?= 7798
FASTEMBED_METRICS_PORT ?= 9091
FASTEMBED_DAEMON_ENDPOINT ?= http://localhost:$(FASTEMBED_GRPC_PORT)
FASTEMBED_LOG_LEVEL ?= info

FLOW_ARGS = -RepoDir "$(REPO)" -UpstreamUrl "$(UPSTREAM_URL)" -MainBranch "$(MAIN_BRANCH)" -DevBranch "$(DEV_BRANCH)" -UpstreamSyncBranch "$(UPSTREAM_SYNC_BRANCH)" -Strategy "$(SYNC_STRATEGY)" -Push "$(PUSH)"
TENANT_ARGS = -RepoDir "$(REPO)" -PatchPath "$(TENANT_PATCH)" -ExtraPatchPath "$(TENANT_HARDEN_PATCH)"
OBS_ARGS = -RepoDir "$(REPO)" -ProjectDir "$(PROJECT)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)" -LogDir "$(LOG_DIR)"
WORKSPACE_ARGS = -RegistryPath "$(REGISTRY)" -Name "$(WORKSPACE_NAME)" -ProjectDir "$(WORKSPACE_PROJECT)" -MainBranch "$(MAIN_BRANCH)" -DevBranch "$(DEV_BRANCH)" -UpstreamSyncBranch "$(UPSTREAM_SYNC_BRANCH)" -UpstreamUrl "$(UPSTREAM_URL)" -UpstreamRef "upstream/$(MAIN_BRANCH)" -FixBranch "$(WORKSPACE_FIX_BRANCH)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)" -LogDir "$(LOG_DIR)" -Push "$(PUSH)"
INDEX_ARGS = -RegistryPath "$(INDEX_REGISTRY)" -ProjectName "$(INDEX_PROJECT_NAME)" -ProjectDir "$(INDEX_PROJECT)" -BranchName "$(INDEX_BRANCH)" -BaseBranch "$(INDEX_BASE_BRANCH)" -ReturnBranch "$(INDEX_RETURN_BRANCH)" -WorktreePath "$(INDEX_WORKTREE_PATH)" -WorktreeRoot "$(INDEX_WORKTREE_ROOT)" -UseWorktree "$(INDEX_USE_WORKTREE)" -Purpose "$(INDEX_PURPOSE)" -CreatedBy "$(INDEX_CREATED_BY)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)" -LogDir "$(LOG_DIR)" -Mutate "$(INDEX_MUTATE)"
FASTEMBED_OBS_ARGS = -RepoDir "$(REPO)" -ProjectDir "$(PROJECT)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(FASTEMBED_DAEMON_ENDPOINT)" -LogDir "$(LOG_DIR)"
FASTEMBED_SERVICE_ARGS = -FastEmbed -FastEmbedCacheDir "$(FASTEMBED_CACHE_DIR)" -FastEmbedQdrantUrl "$(FASTEMBED_QDRANT_URL)" -FastEmbedGrpcPort $(FASTEMBED_GRPC_PORT) -FastEmbedControlPort $(FASTEMBED_CONTROL_PORT) -FastEmbedMetricsPort $(FASTEMBED_METRICS_PORT) -FastEmbedLogLevel "$(FASTEMBED_LOG_LEVEL)"
FASTEMBED_DAEMON_ARGS = -RepoDir "$(REPO)" -CacheDir "$(FASTEMBED_CACHE_DIR)" -QdrantUrl "$(FASTEMBED_QDRANT_URL)" -GrpcPort $(FASTEMBED_GRPC_PORT) -ControlPort $(FASTEMBED_CONTROL_PORT) -MetricsPort $(FASTEMBED_METRICS_PORT) -LogLevel "$(FASTEMBED_LOG_LEVEL)"

.PHONY: help doctor bootstrap fork-branch pull-upstream push pr \
	qdrant-up qdrant-up-grpc \
	compose-up compose-down compose-ps \
	stack-up stack-down stack-restart stack-status stack-logs \
	mcp-rebuild memexd-recreate health-quick first-time redeploy \
	build-ts test-ts typecheck-ts build-rust \
	start-daemon start-daemon-fastembed \
	config config-fastembed config-claude-http \
	apply-config apply-config-fastembed apply-config-claude-http \
	codex-open register \
	smoke smoke-full semantic-smoke semantic-search-library-smoke semantic-search-project-smoke \
	status clean \
	branch-help branch-status \
	sync-upstream sync-dev promote \
	fix-start fix-promote tag-main \
	tenant-check tenant-apply tenant-validate tenant-flow \
	health observe observability-snapshot \
	incremental-check incremental-repair \
	service-stabilize service-stabilize-fastembed reliability-doctor \
	workspace-help workspace-init workspace-add workspace-remove workspace-list \
	workspace-status workspace-status-all workspace-sync workspace-sync-all \
	workspace-fix-start workspace-fix-promote workspace-observe-all \
	mcp-manager-check mcp-manager-apply mcp-manager-validate \
	index-help index-init \
	index-hooks-install index-hooks-uninstall index-hooks-status \
	index-project-add index-project-list index-project-status \
	index-status-all index-branch-list \
	index-agent-start index-agent-finish index-agent-abandon index-agent-status \
	index-observe index-observe-all index-prune-orphans \
	index-incremental-check index-incremental-check-all \
	index-register-wqm index-register-all-wqm \
	workspace-index-check workspace-index-apply workspace-index-validate \
	up up-fastembed

help:
	@Write-Host "============================================================"
	@Write-Host "Stack lifecycle (use estes para o dia-a-dia):"
	@Write-Host "  first-time          - SETUP DO ZERO: build TS + docker up + hooks + health"
	@Write-Host "  redeploy            - APOS MERGE / git pull: build + recreate mcp+memexd + hooks"
	@Write-Host "  stack-up            - start docker stack (sem rebuild)"
	@Write-Host "  stack-down          - stop docker stack"
	@Write-Host "  stack-restart       - down + up"
	@Write-Host "  stack-status        - ps + ping admin/qdrant/daemon"
	@Write-Host "  stack-logs          - tail logs do mcp e memexd"
	@Write-Host "  mcp-rebuild         - rebuild MCP image apos mudancas em src/typescript/"
	@Write-Host "  memexd-recreate     - recreate memexd (apos mudar env do daemon)"
	@Write-Host "  health-quick        - curl /admin/api/health"
	@Write-Host "============================================================"
	@Write-Host "Targets principais (legacy / build-only daemon local):"
	@Write-Host "  up                  - compila tudo, sobe Qdrant/daemon padrao e aplica config MCP"
	@Write-Host "  up-fastembed        - compila tudo, sobe Qdrant/daemon com FastEmbed e aplica config MCP"
	@Write-Host "  compose-up          - sobe docker-compose.yml da raiz com build local do MCP"
	@Write-Host "  compose-down        - para o stack unificado"
	@Write-Host "  compose-ps          - mostra o status do stack unificado"
	@Write-Host "  doctor              - verifica dependencias, repo, Qdrant, daemon e configs"
	@Write-Host "  qdrant-up           - sobe Qdrant via Docker"
	@Write-Host "  qdrant-up-grpc      - sobe Qdrant via Docker com porta gRPC 6334"
	@Write-Host "  start-daemon-fastembed - inicia memexd local com FastEmbed e gRPC"
	@Write-Host "  build-ts            - instala deps e compila MCP TypeScript"
	@Write-Host "  config/apply-config - gera/aplica configs Claude Desktop (http://localhost:50051) e Codex HTTP (http://localhost:6335/mcp)"
	@Write-Host "  config-claude-http/apply-config-claude-http - Claude Desktop via mcp-remote bridge para o container HTTP (:6335/mcp). Requer: npm install -g mcp-remote"
	@Write-Host "  config-fastembed/apply-config-fastembed - mesma base, com Codex/Claude no fluxo FastEmbed local (http://localhost:55151)"
	@Write-Host "  codex-open          - abre o Codex carregando MCP_HTTP_TOKEN de docker/.env"
	@Write-Host "  register            - registra PROJECT no wqm"
	@Write-Host "  smoke               - valida fluxo minimo wqm/Qdrant/daemon"
	@Write-Host "  smoke-full          - smoke + tenant validate + incremental-check + health"
	@Write-Host "  semantic-smoke      - roda os smokes de busca semantica em biblioteca e projeto"
	@Write-Host "  semantic-search-library-smoke - forca uma busca semantica na collection libraries"
	@Write-Host "  semantic-search-project-smoke - registra projeto temporario e forca busca semantica"
	@Write-Host ""
	@Write-Host "Confiabilidade / observabilidade:"
	@Write-Host "  health              - snapshot unico de saude em JSONL + resumo humano"
	@Write-Host "  observe             - monitor continuo de Qdrant/daemon/wqm/queue/projeto"
	@Write-Host "  incremental-check   - valida registro, watch e consistencia incremental do PROJECT"
	@Write-Host "  incremental-repair  - tenta reparos nao destrutivos: register, watch resume, check"
	@Write-Host "  service-stabilize   - tenta iniciar Qdrant/daemon e grava diagnostico"
	@Write-Host "  service-stabilize-fastembed - sobe Qdrant/daemon com FastEmbed e gRPC"
	@Write-Host "  reliability-doctor  - health + incremental-check + tenant-validate"
	@Write-Host ""
	@Write-Host "Fluxo de branches (main estavel <- dev <- upstream-sync):"
	@Write-Host "  branch-help   - explica o modelo de branches"
	@Write-Host "  branch-status - mostra branches e log resumido"
	@Write-Host "  sync-upstream - ff upstream-sync a partir de upstream/main"
	@Write-Host "  sync-dev      - traz upstream-sync para dev (sync-upstream + merge)"
	@Write-Host "  promote       - promove dev -> main (so quando estavel/CI verde)"
	@Write-Host "  fix-start     - cria FIX_BRANCH a partir de dev"
	@Write-Host "  fix-promote   - merge de FIX_BRANCH em dev"
	@Write-Host ""
	@Write-Host "Tenant fix:"
	@Write-Host "  tenant-check    - verifica se patches de tenant sao aplicaveis ou ja estao presentes"
	@Write-Host "  tenant-apply    - aplica tenant fix + hardening na branch atual (nunca main)"
	@Write-Host "  tenant-validate - confirma marcadores do tenant fix/hardening"
	@Write-Host "  tenant-flow     - cria branch fix/*, aplica tenant fix e mostra proximos passos"
	@Write-Host ""
	@Write-Host "Multi-projeto / multi-branch:"
	@Write-Host "  workspace-help       - explica registry local multi-projeto"
	@Write-Host "  workspace-init       - inicializa .wqm-fork/projects.json"
	@Write-Host "  workspace-add        - adiciona WORKSPACE_PROJECT com WORKSPACE_NAME"
	@Write-Host "  workspace-status-all - status git/branches de todos os projetos"
	@Write-Host "  workspace-sync-all   - sincroniza upstream-sync->dev em todos os projetos"
	@Write-Host "  workspace-fix-start  - cria branch de correcao em um projeto sem tocar na main"
	@Write-Host "  workspace-fix-promote- promove correcao para dev"
	@Write-Host ""
	@Write-Host "Projetos indexados / branches de agentes:"
	@Write-Host "  index-help                  - explica indexed-projects.json e agent branches"
	@Write-Host "  index-init                  - inicializa .wqm-fork/indexed-projects.json"
	@Write-Host "  index-hooks-install         - instala hooks POSIX em .wqm-fork/git-hooks (sobrescreve PS legacy)"
	@Write-Host "  index-hooks-uninstall       - remove hooks WQM gerados em .wqm-fork/git-hooks"
	@Write-Host "  index-hooks-status          - mostra hooksPath atual e arquivos gerados"
	@Write-Host "  index-project-add           - registra projeto indexado e tenta registrar no daemon"
	@Write-Host "  index-project-list          - lista projetos indexados"
	@Write-Host "  index-project-status        - status do projeto/branches/agentes"
	@Write-Host "  index-agent-start           - cria branch de agente, preferencialmente em worktree, e registra no daemon"
	@Write-Host "  index-register-wqm          - re-registra projeto/branches no daemon"
	@Write-Host "  index-agent-finish          - marca branch de agente como pronta sem merge"
	@Write-Host "  index-agent-abandon         - marca branch de agente como abandonada sem deletar por padrao"
	@Write-Host "  index-observe-all           - observabilidade de todos os projetos indexados"
	@Write-Host "  index-prune-orphans         - remove do registry branches/worktrees que nao existem mais"
	@Write-Host "  index-incremental-check-all - checagem incremental de todos os projetos/branches"
	@Write-Host ""
	@Write-Host "MCP workspace_index:"
	@Write-Host "  workspace-index-check       - valida patch MCP workspace_index"
	@Write-Host "  workspace-index-apply       - aplica ferramenta MCP workspace_index"
	@Write-Host "  workspace-index-validate    - confirma ferramenta MCP instalada"
	@Write-Host ""
	@Write-Host "MCP workspace manager legado:"
	@Write-Host "  mcp-manager-check    - valida se patch MCP fork_workspace aplica"
	@Write-Host "  mcp-manager-apply    - aplica ferramenta MCP local fork_workspace"
	@Write-Host "  mcp-manager-validate - confirma ferramenta MCP instalada"
	@Write-Host ""
	@Write-Host "Exemplos:"
	@Write-Host "  make -f Makefile.win sync-dev PUSH=true"
	@Write-Host "  make -f Makefile.win tenant-flow"
	@Write-Host "  make -f Makefile.win observe PROJECT=C:\dev\meu-projeto OBS_INTERVAL=15"

branch-help:
	@Write-Host "Modelo de branches deste fork (GitFlow-lite):"
	@Write-Host ""
	@Write-Host "  upstream/main --(ff)--> $(UPSTREAM_SYNC_BRANCH) --(merge)--> $(DEV_BRANCH) --(promote)--> $(MAIN_BRANCH)"
	@Write-Host ""
	@Write-Host "Papel de cada branch:"
	@Write-Host "  $(MAIN_BRANCH): versao estavel/funcional. So recebe promocoes estaveis."
	@Write-Host "  $(DEV_BRANCH): linha de trabalho ativa (CI roda aqui). Feature branches saem daqui."
	@Write-Host "  $(UPSTREAM_SYNC_BRANCH): espelho limpo de upstream/main (fetch-only, nunca commitar)."
	@Write-Host ""
	@Write-Host "Correcoes nascem de $(DEV_BRANCH):"
	@Write-Host "  make -f Makefile.win fix-start FIX_BRANCH=fix/minha-correcao"
	@Write-Host "  make -f Makefile.win fix-promote FIX_BRANCH=fix/minha-correcao"
	@Write-Host ""
	@Write-Host "Promover para main (so quando estavel): make -f Makefile.win promote"
	@Write-Host "upstream e fetch-only: o push para upstream esta desabilitado de proposito."

branch-status:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action status

sync-upstream:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action sync-upstream

sync-dev:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action sync-dev

promote:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action promote

fix-start:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action start-fix -FixBranch "$(FIX_BRANCH)"

fix-promote:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action finish-fix -FixBranch "$(FIX_BRANCH)"

tag-main:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action tag-main -Tag "$(TAG)"

tenant-check:
	.\scripts\windows\apply-tenant-fix.ps1 $(TENANT_ARGS) -CheckOnly

tenant-apply:
	.\scripts\windows\apply-tenant-fix.ps1 $(TENANT_ARGS)

tenant-validate:
	.\scripts\windows\apply-tenant-fix.ps1 $(TENANT_ARGS) -ValidateOnly

tenant-flow:
	.\scripts\windows\branch-flow.ps1 $(FLOW_ARGS) -Action start-fix -FixBranch "$(FIX_BRANCH)"
	.\scripts\windows\apply-tenant-fix.ps1 $(TENANT_ARGS)
	@Write-Host "Proximos passos: make -f Makefile.win typecheck-ts; make -f Makefile.win test-ts; git add src/typescript/mcp-server/src/tools; git commit -m 'fix(mcp/rules): scope rule mutations by tenant'"

workspace-help:
	@Write-Host "Registry multi-projeto: $(REGISTRY)"
	@Write-Host "Fluxo por projeto: upstream/main -> upstream-sync -> dev (a main so recebe promocoes estaveis)"
	@Write-Host "Adicionar: make -f Makefile.win workspace-add WORKSPACE_NAME=nome WORKSPACE_PROJECT=C:\dev\repo"
	@Write-Host "Status:    make -f Makefile.win workspace-status-all"
	@Write-Host "Sync all:  make -f Makefile.win workspace-sync-all PUSH=true"

workspace-init:
	.\scripts\windows\workspace-registry.ps1 -RegistryPath "$(REGISTRY)" -Action init -Mutate true

workspace-add:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action add -Mutate true

workspace-remove:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action remove -Mutate true

workspace-list:
	.\scripts\windows\workspace-registry.ps1 -RegistryPath "$(REGISTRY)" -Action list

workspace-status:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action status

workspace-status-all:
	.\scripts\windows\workspace-registry.ps1 -RegistryPath "$(REGISTRY)" -Action status-all

workspace-sync:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action sync-project -Mutate true

workspace-sync-all:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action sync-all -Mutate true

workspace-fix-start:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action start-fix -Mutate true

workspace-fix-promote:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action promote-fix -Mutate true

workspace-observe-all:
	.\scripts\windows\workspace-registry.ps1 $(WORKSPACE_ARGS) -Action observe-all

mcp-manager-check:
	.\scripts\windows\mcp-workspace-manager.ps1 -RepoDir "$(REPO)" -PatchPath "$(MCP_MANAGER_PATCH)" -CheckOnly

mcp-manager-apply:
	.\scripts\windows\mcp-workspace-manager.ps1 -RepoDir "$(REPO)" -PatchPath "$(MCP_MANAGER_PATCH)"

mcp-manager-validate:
	.\scripts\windows\mcp-workspace-manager.ps1 -RepoDir "$(REPO)" -PatchPath "$(MCP_MANAGER_PATCH)" -ValidateOnly


index-help:
	@Write-Host "Registry de projetos indexados: $(INDEX_REGISTRY)"
	@Write-Host "Este registry e diferente do fluxo do fork. Ele controla projetos, branches e worktrees criados por agentes."
	@Write-Host "Fluxo seguro: start-agent-branch -> trabalhar -> finish-agent-branch -> revisao humana -> merge manual."
	@Write-Host "Nao ha merge automatico para main/original. Use worktrees para branches paralelas."

index-init:
	.\scripts\windows\indexed-projects-registry.ps1 -RegistryPath "$(INDEX_REGISTRY)" -Action init -Mutate true

index-hooks-install:
	@Write-Host "Installing POSIX git hooks (sh + curl -> MCP HTTP)..."
	@$$sh = (.\scripts\windows\find-sh.ps1); if ($$LASTEXITCODE -ne 0) { exit 1 }; $$env:PATH = (Split-Path $$sh -Parent) + ';' + $$env:PATH; & $$sh scripts/git-hooks/install.sh --repo "$(REPO)" --hooks-dir "$(REPO)/.wqm-fork/git-hooks" --force

index-hooks-uninstall:
	@$$sh = (.\scripts\windows\find-sh.ps1); if ($$LASTEXITCODE -ne 0) { exit 1 }; $$env:PATH = (Split-Path $$sh -Parent) + ';' + $$env:PATH; & $$sh scripts/git-hooks/install.sh --repo "$(REPO)" --hooks-dir "$(REPO)/.wqm-fork/git-hooks" --uninstall

index-hooks-status:
	.\scripts\windows\indexed-projects-hooks.ps1 -Action status -RepoDir "$(REPO)"

index-project-add:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action add-project

index-project-list:
	.\scripts\windows\indexed-projects-registry.ps1 -RegistryPath "$(INDEX_REGISTRY)" -Action list-projects

index-project-status:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action project-status

index-status-all:
	.\scripts\windows\indexed-projects-registry.ps1 -RegistryPath "$(INDEX_REGISTRY)" -Action status-all -LogDir "$(LOG_DIR)"

index-branch-list:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action list-branches

index-agent-start:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action start-agent-branch

index-agent-finish:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action finish-agent-branch

index-agent-abandon:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action abandon-agent-branch

index-agent-status:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action agent-branch-status

index-observe:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action observe-project

index-observe-all:
	.\scripts\windows\indexed-projects-registry.ps1 -RegistryPath "$(INDEX_REGISTRY)" -Action observe-all -LogDir "$(LOG_DIR)"

index-prune-orphans:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action cleanup-orphans

index-incremental-check:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action incremental-check

index-incremental-check-all:
	.\scripts\windows\indexed-projects-registry.ps1 -RegistryPath "$(INDEX_REGISTRY)" -Action incremental-check-all -LogDir "$(LOG_DIR)"

index-register-wqm:
	.\scripts\windows\indexed-projects-registry.ps1 $(INDEX_ARGS) -Action register-wqm

index-register-all-wqm:
	.\scripts\windows\indexed-projects-registry.ps1 -RegistryPath "$(INDEX_REGISTRY)" -Action register-all-wqm -LogDir "$(LOG_DIR)" -Mutate "$(INDEX_MUTATE)"

workspace-index-check:
	.\scripts\windows\mcp-workspace-manager.ps1 -RepoDir "$(REPO)" -PatchPath "$(WORKSPACE_INDEX_PATCH)" -CheckOnly

workspace-index-apply:
	.\scripts\windows\mcp-workspace-manager.ps1 -RepoDir "$(REPO)" -PatchPath "$(WORKSPACE_INDEX_PATCH)"

workspace-index-validate:
	.\scripts\windows\mcp-workspace-manager.ps1 -RepoDir "$(REPO)" -PatchPath "$(WORKSPACE_INDEX_PATCH)" -ValidateOnly

up: build-ts build-rust apply-config service-stabilize

up-fastembed: build-ts build-rust apply-config-fastembed service-stabilize-fastembed

doctor:
	.\scripts\windows\doctor.ps1 -RepoDir "$(REPO)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)"

bootstrap:
	.\scripts\windows\bootstrap.ps1 -RepoDir "$(REPO)" -Branch "$(BRANCH)"

fork-branch:
	.\scripts\windows\git-flow.ps1 -RepoDir "$(REPO)" -Branch "$(BRANCH)" -Action branch

pull-upstream:
	.\scripts\windows\git-flow.ps1 -RepoDir "$(REPO)" -Branch "$(BRANCH)" -Action sync

push:
	.\scripts\windows\git-flow.ps1 -RepoDir "$(REPO)" -Branch "$(BRANCH)" -Action push

pr:
	@Write-Host "Promocao dev -> main: 'make -f Makefile.win promote' (merge local) ou 'gh pr create --base $(MAIN_BRANCH) --head $(DEV_BRANCH)'."
	@Write-Host "PR para o upstream (ChrisGVE) e decisao humana; o push para upstream esta desabilitado."

qdrant-up:
	.\scripts\windows\start-qdrant.ps1 -QdrantUrl "$(QDRANT_URL)"

qdrant-up-grpc:
	.\scripts\windows\start-qdrant.ps1 -QdrantUrl "$(QDRANT_URL)" -HttpPort $(QDRANT_HTTP_PORT) -GrpcPort $(QDRANT_GRPC_PORT) -EnsureGrpc

compose-up:
	@if (-not (Test-Path "$(COMPOSE_ENV_FILE)")) { Write-Host "ERROR: $(COMPOSE_ENV_FILE) nao encontrado. Copie docker\.env.example para docker\.env." -ForegroundColor Red; exit 1 }
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" up -d --build

compose-down:
	@if (-not (Test-Path "$(COMPOSE_ENV_FILE)")) { Write-Host "ERROR: $(COMPOSE_ENV_FILE) nao encontrado." -ForegroundColor Red; exit 1 }
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" down

compose-ps:
	@if (-not (Test-Path "$(COMPOSE_ENV_FILE)")) { Write-Host "ERROR: $(COMPOSE_ENV_FILE) nao encontrado." -ForegroundColor Red; exit 1 }
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" ps

# Stack lifecycle (docker-compose orchestration). Veja `make -f Makefile.win help`.

stack-up:
	@Write-Host "Starting docker stack..."
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" up -d
	@Write-Host "Stack started. Run 'make -f Makefile.win stack-status' to verify."

stack-down:
	@Write-Host "Stopping docker stack..."
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" down

stack-restart: stack-down stack-up

stack-status:
	@Write-Host "=== docker compose ps ==="
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" ps
	@Write-Host ""
	@Write-Host "=== endpoints ==="
	@try { $$resp = Invoke-WebRequest -Uri "$(MCP_INIT_URL)" -UseBasicParsing -TimeoutSec 3 -ErrorAction Stop; Write-Host "/admin/init     [$$($$resp.StatusCode)] ok" } catch { Write-Host "/admin/init     [fail] $$($$_.Exception.Message)" }
	@try { $$resp = Invoke-WebRequest -Uri "http://localhost:6333/collections" -UseBasicParsing -TimeoutSec 3 -ErrorAction Stop; Write-Host "qdrant          [$$($$resp.StatusCode)] ok" } catch { Write-Host "qdrant          [fail] $$($$_.Exception.Message)" }
	@try { $$client = New-Object System.Net.Sockets.TcpClient; $$iar = $$client.BeginConnect("localhost", 50051, $$null, $$null); $$ok = $$iar.AsyncWaitHandle.WaitOne(2000, $$false); if ($$ok) { $$client.EndConnect($$iar); Write-Host "memexd gRPC     [ok] localhost:50051" } else { Write-Host "memexd gRPC     [timeout]" }; $$client.Close() } catch { Write-Host "memexd gRPC     [fail] $$($$_.Exception.Message)" }
	@try { $$resp = Invoke-WebRequest -Uri "http://localhost:3200/ready" -UseBasicParsing -TimeoutSec 3 -ErrorAction Stop; Write-Host "tempo           [$$($$resp.StatusCode)] ready" } catch { Write-Host "tempo           [fail] $$($$_.Exception.Message)" }

stack-logs:
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" logs --tail 50 mcp memexd

mcp-rebuild: build-ts
	@Write-Host "Rebuilding MCP image..."
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" build mcp
	@Write-Host "Recreating MCP container..."
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" up -d mcp

memexd-recreate:
	@Write-Host "Recreating memexd container (picks up env changes)..."
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" up -d --force-recreate memexd

health-quick:
	@$$token = (Get-Content "$(COMPOSE_ENV_FILE)" -ErrorAction SilentlyContinue | Select-String "^MCP_HTTP_TOKEN=" | ForEach-Object { $$_.ToString().Split("=",2)[1] } | Select-Object -First 1); $$headers = @{}; if ($$token) { $$headers["Authorization"] = "Bearer $$token" }; try { $$resp = Invoke-RestMethod -Uri "$(MCP_HEALTH_URL)" -TimeoutSec 5 -Headers $$headers; $$resp | ConvertTo-Json -Depth 10 } catch { Write-Host "health check failed: $$($$_.Exception.Message)" -ForegroundColor Red; exit 1 }

first-time:
	@Write-Host "=== First-time setup ==="
	@Write-Host "Step 1/4: npm install + build MCP server"
	@$(MAKE) -f $(firstword $(MAKEFILE_LIST)) build-ts
	@Write-Host "Step 2/4: build + start docker stack"
	@docker volume create workspace-qdrant-mcp_memexd_db | Out-Null
	@if (Test-Path "$(COMPOSE_ENV_FILE)") { Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" up -d --build } else { Write-Host "ERROR: docker/.env not found. Copy docker/.env.example first." -ForegroundColor Red; exit 1 }
	@Write-Host "Step 3/4: install POSIX git hooks"
	@$(MAKE) -f $(firstword $(MAKEFILE_LIST)) index-hooks-install
	@Write-Host "Step 4/4: health check"
	@Start-Sleep -Seconds 8
	@$(MAKE) -f $(firstword $(MAKEFILE_LIST)) stack-status
	@Write-Host ""
	@Write-Host "=== Done. Open http://localhost:$(MCP_HTTP_PORT)/admin/ ==="

redeploy: build-ts
	@Write-Host "=== Redeploy after code changes ==="
	@Write-Host "Step 1/4: rebuild MCP + memexd images"
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" build mcp memexd
	@Write-Host "Step 2/4: recreate mcp + memexd (env may have changed)"
	@docker volume create workspace-qdrant-mcp_memexd_db | Out-Null
	@Set-Location "$(REPO)"; docker compose --env-file "$(COMPOSE_ENV_FILE)" -f "$(COMPOSE_FILE)" up -d --force-recreate mcp memexd
	@Write-Host "Step 3/4: reinstall git hooks (idempotent)"
	@$(MAKE) -f $(firstword $(MAKEFILE_LIST)) index-hooks-install
	@Write-Host "Step 4/4: health check"
	@Start-Sleep -Seconds 6
	@$(MAKE) -f $(firstword $(MAKEFILE_LIST)) stack-status
	@Write-Host ""
	@Write-Host "=== Redeploy complete ==="

build-ts:
	Set-Location "$(REPO)\src\typescript\mcp-server"; npm install; npm run build

test-ts:
	Set-Location "$(REPO)\src\typescript\mcp-server"; npm test

typecheck-ts:
	Set-Location "$(REPO)\src\typescript\mcp-server"; npm run typecheck

build-rust:
	Set-Location "$(REPO)\src\rust"; cargo build --manifest-path Cargo.toml --workspace

start-daemon:
	.\scripts\windows\start-daemon.ps1 -RepoDir "$(REPO)"

start-daemon-fastembed:
	.\scripts\windows\start-daemon-fastembed.ps1 $(FASTEMBED_DAEMON_ARGS)

config:
	.\scripts\windows\gen-mcp-config.ps1 -RepoDir "$(REPO)" -ServerName "$(SERVER_NAME)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)" -CodexTransport http -ToolCsv "$(TOOLS)"

config-fastembed:
	.\scripts\windows\gen-mcp-config.ps1 -RepoDir "$(REPO)" -ServerName "$(SERVER_NAME)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(FASTEMBED_DAEMON_ENDPOINT)" -CodexTransport stdio -ToolCsv "$(TOOLS)" -ConfigSuffix ".fastembed"

apply-config:
	.\scripts\windows\gen-mcp-config.ps1 -RepoDir "$(REPO)" -ServerName "$(SERVER_NAME)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)" -CodexTransport http -ToolCsv "$(TOOLS)" -ApplyClaude -ApplyCodex

config-claude-http:
	.\scripts\windows\gen-mcp-config.ps1 -RepoDir "$(REPO)" -ServerName "$(SERVER_NAME)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)" -ClaudeTransport http -ClaudeHttpUrl http://localhost:$(MCP_HTTP_PORT)/mcp -CodexTransport http -ToolCsv "$(TOOLS)"

apply-config-claude-http:
	.\scripts\windows\gen-mcp-config.ps1 -RepoDir "$(REPO)" -ServerName "$(SERVER_NAME)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)" -ClaudeTransport http -ClaudeHttpUrl http://localhost:$(MCP_HTTP_PORT)/mcp -CodexTransport http -ToolCsv "$(TOOLS)" -ApplyClaude -ApplyCodex

apply-config-fastembed:
	.\scripts\windows\gen-mcp-config.ps1 -RepoDir "$(REPO)" -ServerName "$(SERVER_NAME)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(FASTEMBED_DAEMON_ENDPOINT)" -CodexTransport stdio -ToolCsv "$(TOOLS)" -ConfigSuffix ".fastembed" -ApplyClaude -ApplyCodex

codex-open:
	.\scripts\windows\start-codex.ps1 -RepoDir "$(REPO)"

register:
	.\scripts\windows\register-project.ps1 -ProjectDir "$(PROJECT)"

smoke:
	.\scripts\windows\smoke-test.ps1 -RepoDir "$(REPO)" -ProjectDir "$(PROJECT)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)"

smoke-full: service-stabilize smoke tenant-validate incremental-check health

semantic-search-library-smoke:
	.\scripts\windows\semantic-search-library-smoke.ps1 -RepoDir "$(REPO)" -McpUrl "http://localhost:$(MCP_HTTP_PORT)/mcp"

semantic-search-project-smoke:
	.\scripts\windows\semantic-search-project-smoke.ps1 -RepoDir "$(REPO)" -McpUrl "http://localhost:$(MCP_HTTP_PORT)/mcp"

semantic-smoke: semantic-search-library-smoke semantic-search-project-smoke

health:
	.\scripts\windows\service-observe.ps1 $(OBS_ARGS) -Once

observability-snapshot: health

observe:
	.\scripts\windows\service-observe.ps1 $(OBS_ARGS) -IntervalSeconds $(OBS_INTERVAL)

incremental-check:
	.\scripts\windows\incremental-check.ps1 -RepoDir "$(REPO)" -ProjectDir "$(PROJECT)" -LogDir "$(LOG_DIR)"

incremental-repair:
	.\scripts\windows\incremental-check.ps1 -RepoDir "$(REPO)" -ProjectDir "$(PROJECT)" -LogDir "$(LOG_DIR)" -Repair

service-stabilize:
	.\scripts\windows\service-stabilize.ps1 $(OBS_ARGS)

service-stabilize-fastembed:
	.\scripts\windows\service-stabilize.ps1 $(FASTEMBED_OBS_ARGS) $(FASTEMBED_SERVICE_ARGS)

reliability-doctor: health incremental-check tenant-validate

status:
	.\scripts\windows\status.ps1 -RepoDir "$(REPO)" -QdrantUrl "$(QDRANT_URL)" -DaemonEndpoint "$(DAEMON_ENDPOINT)"

clean:
	if (Test-Path "$(REPO)\src\typescript\mcp-server\dist") { Remove-Item -Recurse -Force "$(REPO)\src\typescript\mcp-server\dist" }
