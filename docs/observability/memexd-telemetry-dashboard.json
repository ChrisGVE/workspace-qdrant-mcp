{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Reference dashboard for memexd telemetry (issue-64): queue throughput/latency, watcher events, gRPC request rate/latency, embedding/SQLite/Qdrant latency.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Queue depth by item_type / status",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "memexd_unified_queue_depth",
          "legendFormat": "{{item_type}}/{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Queue throughput (dequeues / s)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (item_type) (rate(memexd_unified_queue_dequeues_total[5m]))",
          "legendFormat": "{{item_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3,
      "title": "Queue processing latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, item_type) (rate(memexd_unified_queue_processing_time_seconds_bucket[5m])))",
          "legendFormat": "{{item_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Watcher events rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(memexd_watcher_events_total[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        },
        {
          "expr": "sum by (reason) (rate(memexd_watcher_coalesced_total[5m]))",
          "legendFormat": "coalesced/{{reason}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "title": "gRPC request rate by service/method",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service, method) (rate(memexd_grpc_requests_total[5m]))",
          "legendFormat": "{{service}}/{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "title": "gRPC latency p95",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service, method) (rate(memexd_grpc_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}}/{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Embedding batch latency p95 by model",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(memexd_embedding_duration_seconds_bucket[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "title": "Qdrant op latency p95",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, op) (rate(memexd_qdrant_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9,
      "title": "SQLite write latency p95",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, op) (rate(memexd_sqlite_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10,
      "title": "Qdrant errors rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (op, error_type) (rate(memexd_qdrant_request_errors_total[5m]))",
          "legendFormat": "{{op}} {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["memexd", "telemetry", "issue-64"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "memexd — telemetry (issue-64)",
  "uid": "memexd-telemetry-issue-64",
  "version": 1
}
