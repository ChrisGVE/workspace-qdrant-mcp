# docker/.env.example
#
# Environment variables for workspace-qdrant-mcp Docker deployments.
# Copy to docker/.env and fill in values appropriate for your environment.
#
#   cp docker/.env.example docker/.env
#
# All compose files under docker/compose/ reference this file via:
#   env_file: ../.env

# ── Qdrant ────────────────────────────────────────────────────────────────────

# URL of the Qdrant server.
#
# memexd connects to Qdrant via gRPC (port 6334); the MCP server connects
# via REST (port 6333). Set the correct port for each service.
#
# minimal / standalone deployments:
#   Use host.docker.internal to reach Qdrant running on the Docker host,
#   or a fully-qualified URL for a remote/cloud instance.
#   For memexd:   QDRANT_URL=http://host.docker.internal:6334
#   For MCP:      QDRANT_URL=http://host.docker.internal:6333
#
# full-stack deployment:
#   Use the main-docker service name "qdrant" (containers share a network).
#   Example: QDRANT_URL=http://qdrant:6334   (memexd)
#            QDRANT_URL=http://qdrant:6333   (mcp)
QDRANT_URL=http://host.docker.internal:6334

# API key for Qdrant Cloud or a secured self-hosted instance.
# Leave empty for unauthenticated local deployments.
QDRANT_API_KEY=

# ── memexd daemon ─────────────────────────────────────────────────────────────

# Log level for the Rust daemon.
# Values: ERROR | WARN | INFO | DEBUG | TRACE
WQM_LOG_LEVEL=INFO

# Path to the SQLite database inside the container (XDG data home layout).
# Change only if you remap the workspace-qdrant volume mount.
# WQM_DATABASE_PATH=/home/memexd/.local/share/workspace-qdrant/memexd.db

# FastEmbed embedding model.
# Default: all-MiniLM-L6-v2 (384-dim, fast, runs CPU-only)
# FASTEMBED_MODEL=all-MiniLM-L6-v2

# Host port published for the memexd gRPC service.
# Used by minimal.yml and standalone-memexd.yml; not published in full-stack.yml.
MEMEXD_GRPC_PORT=50051

# Host port published for the memexd Prometheus metrics endpoint (/metrics, /health).
# Used by minimal.yml and standalone-memexd.yml; not published in full-stack.yml.
MEMEXD_METRICS_PORT=9091

# ── MCP server ────────────────────────────────────────────────────────────────

# gRPC endpoint the MCP server uses to reach memexd.
# WQM_DAEMON_ENDPOINT is the preferred variable; MEMEXD_GRPC_URL is accepted as
# an alias for backward compatibility. Both accept "host:port" or "http://host:port".
# Default points to the compose service name; override for external memexd instances.
WQM_DAEMON_ENDPOINT=memexd:50051
# MEMEXD_GRPC_URL=http://memexd:50051  # alias -- use WQM_DAEMON_ENDPOINT instead

# Transport mode for the MCP server.
# stdio -- standard I/O transport; used by Claude Code (default).
# http  -- HTTP transport; enables /metrics on MCP_METRICS_PORT (task 5).
MCP_SERVER_MODE=stdio

# Host port published for the MCP server Prometheus metrics endpoint.
# Used by minimal.yml and standalone-mcp.yml; not published in full-stack.yml.
# This port is reserved for task 5 (metrics HTTP server).
# MCP_METRICS_PORT=9092

# ── Observabilidade (Prometheus + Grafana + Loki + OTel) ──────────────────────

# Portas dos serviços de observabilidade.
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# LOKI_PORT=3100
# OTEL_GRPC_PORT=4317
# OTEL_HTTP_PORT=4318

# Credenciais do Grafana (padrão: admin/admin).
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=admin

# Endpoint OTLP para memexd e MCP enviarem traces.
# Quando usando o docker-compose.yml consolidado, apontar para o otel-collector interno:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Stack unificada na raiz do repositório ───────────────────────────────────

# Requeridos pelo `docker-compose.yml` da raiz:
# MCP_HTTP_TOKEN=<gere com `openssl rand -hex 32`>  # reutilizado pelo Prometheus no scrape do /metrics
# WQM_DEV_ROOT=C:\Users\voce\dev

# FastEmbed local (usado como padrao pelo stack unificado):
# WQM_EMBEDDING_PROVIDER=fastembed
# WQM_FASTEMBED_CACHE_DIR=./.fastembed_cache

# Perfis opcionais do stack unificado:
# COMPOSE_PROFILES=tls,embeddings
#   tls        -> habilita o Caddy com TLS automatico
#   embeddings -> sobe o text-embeddings-inference local
