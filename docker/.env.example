# docker/.env.example
#
# Environment variables for workspace-qdrant-mcp Docker deployments.
# Copy to docker/.env and fill in values appropriate for your environment.
#
#   cp docker/.env.example docker/.env
#
# All compose files under docker/compose/ reference this file via:
#   env_file: ../.env

# ── Qdrant ────────────────────────────────────────────────────────────────────

# URL of the Qdrant server.
#
# memexd connects to Qdrant via gRPC (port 6334); the MCP server connects
# via REST (port 6333). Set the correct port for each service.
#
# minimal / standalone deployments:
#   Use host.docker.internal to reach Qdrant running on the Docker host,
#   or a fully-qualified URL for a remote/cloud instance.
#   For memexd:   QDRANT_URL=http://host.docker.internal:6334
#   For MCP:      QDRANT_URL=http://host.docker.internal:6333
#
# full-stack deployment:
#   Use the main-docker service name "qdrant" (containers share a network).
#   Example: QDRANT_URL=http://qdrant:6334   (memexd)
#            QDRANT_URL=http://qdrant:6333   (mcp)
QDRANT_URL=http://host.docker.internal:6334

# API key for Qdrant Cloud or a secured self-hosted instance.
# Leave empty for unauthenticated local deployments.
QDRANT_API_KEY=

# ── memexd daemon ─────────────────────────────────────────────────────────────

# Log level for the Rust daemon.
# Values: ERROR | WARN | INFO | DEBUG | TRACE
WQM_LOG_LEVEL=INFO

# Path to the SQLite database inside the container (XDG data home layout).
# Change only if you remap the workspace-qdrant volume mount.
# WQM_DATABASE_PATH=/home/memexd/.local/share/workspace-qdrant/memexd.db

# FastEmbed embedding model.
# Default: all-MiniLM-L6-v2 (384-dim, fast, runs CPU-only)
# FASTEMBED_MODEL=all-MiniLM-L6-v2

# Host port published for the memexd gRPC service.
# Used by minimal.yml and standalone-memexd.yml; not published in full-stack.yml.
MEMEXD_GRPC_PORT=50051

# Host port published for the memexd Prometheus metrics endpoint (/metrics, /health).
# Used by minimal.yml and standalone-memexd.yml; not published in full-stack.yml.
MEMEXD_METRICS_PORT=9091

# Process-RSS safety valve in MB. The queue processor pauses for 10s whenever
# the daemon's own RSS exceeds this limit. Default 2048 is conservative; raise
# to 4096 (or higher) on hosts running FastEmbed + heavy mmap workloads.
# WQM_MAX_RSS_MB=4096

# FTS5 batch-mode kill switch for oversize files. When > 0, the FtsBatchProcessor
# falls back to single-file mode whenever ANY pending change has more lines than
# this threshold — even when queue_depth would otherwise pick batch mode.
# Protects RSS by isolating giant files (e.g. 600k-line CSV dumps / generated
# proto / lockfiles) into their own transaction so the rest of the window
# commits quickly. 0 (default) = disabled. Suggested when enabling: 10000.
# WQM_FTS5_SINGLE_MODE_THRESHOLD=10000

# FTS5 HARD CAP: files with more lines than this skip code_lines/FTS5
# ingestion entirely. file_metadata still gets written with fts5_skipped=1
# (visible in admin UI / Grafana panels). Semantic embedding pipeline is
# bounded separately and processes the file normally — only line-level grep
# is skipped. 0 (default) = disabled. Suggested when enabling: 100000
# (~5MB at 50 chars/line, covers most legitimate source files).
# WQM_FTS5_HARD_CAP=100000

# ── MCP server ────────────────────────────────────────────────────────────────

# gRPC endpoint the MCP server uses to reach memexd.
# WQM_DAEMON_ENDPOINT is the preferred variable; MEMEXD_GRPC_URL is accepted as
# an alias for backward compatibility. Both accept "host:port" or "http://host:port".
# Default points to the compose service name; override for external memexd instances.
WQM_DAEMON_ENDPOINT=memexd:50051
# MEMEXD_GRPC_URL=http://memexd:50051  # alias -- use WQM_DAEMON_ENDPOINT instead

# Transport mode for the MCP server.
# stdio -- standard I/O transport; used by Claude Code (default).
# http  -- HTTP transport; enables /metrics on MCP_METRICS_PORT (task 5).
MCP_SERVER_MODE=stdio

# Skip bearer-token check for loopback / Docker-bridge peers. Convenient for
# local admin UI and host-side curls; default in the consolidated compose is 1.
# Set to 0 if the MCP port is exposed beyond localhost.
# MCP_HTTP_TRUST_LOCALHOST=1

# Host port published for the MCP server Prometheus metrics endpoint.
# Used by minimal.yml and standalone-mcp.yml; not published in full-stack.yml.
# This port is reserved for task 5 (metrics HTTP server).
# MCP_METRICS_PORT=9092

# ── Observabilidade (Prometheus + Grafana + Loki + OTel) ──────────────────────

# Portas dos serviços de observabilidade.
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# LOKI_PORT=3100
# OTEL_GRPC_PORT=4317
# OTEL_HTTP_PORT=4318

# Credenciais do Grafana (padrão: admin/admin).
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=admin

# Endpoint OTLP para memexd e MCP enviarem traces.
# Quando usando o docker-compose.yml consolidado, apontar para o otel-collector interno:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Stack unificada na raiz do repositório ───────────────────────────────────

# Requeridos pelo `docker-compose.yml` da raiz:
# MCP_HTTP_TOKEN=<gere com `openssl rand -hex 32`>  # reutilizado pelo Prometheus no scrape do /metrics

# WQM_DEV_ROOT  → "watch root": a pasta que o daemon (memexd) observa e indexa.
# É bind-mounted no MESMO caminho dentro do container (path-transparency, spec 16),
# então o caminho gravado no índice é idêntico ao do host. Escolha UMA das opções:
#
#   Linux / WSL (RECOMENDADO ao rodar o Docker dentro do WSL2):
#     use um caminho ext4 NATIVO do WSL — I/O rápido, file-watching confiável.
#     WQM_DEV_ROOT=/home/<voce>/respositorios
#
#   Windows (Docker Desktop com backend WSL2, repos em NTFS):
#     WQM_DEV_ROOT=C:\Users\voce\dev
#     # Evite apontar para \\wsl.localhost\... ou /mnt/c/... a partir do outro
#     # lado — o bind-mount cruzado (9P/drvfs) é lento e o watch perde eventos.
#
# WQM_DEV_ROOT=/home/<voce>/respositorios
#
# WQM_HOST_DEV_ROOT (opcional): caminho do dev root no HOST quando difere do
# caminho dentro do container (usado para traduzir paths host→container no
# workspace_index). No fluxo WSL nativo, normalmente é igual a WQM_DEV_ROOT.
# WQM_HOST_DEV_ROOT=/home/<voce>/respositorios

# FastEmbed local (provider mais simples, sem servico de embedding):
# WQM_EMBEDDING_PROVIDER=fastembed
# WQM_FASTEMBED_CACHE_DIR=./.fastembed_cache

# Backends de embedding do compose (provider openai_compatible). O daemon
# PREFERE a GPU e cai para a CPU automaticamente (embedding.base_url ->
# wqm-embeddings-gpu:7997, embedding.fallback_base_url -> wqm-embeddings:80
# em state/memexd/config.yaml). Trocar de backend NAO exige reembed.
# WQM_EMBEDDING_PROVIDER=openai_compatible
# OPENAI_API_KEY=local-dev-no-auth   # dummy: TEI/Infinity nao exigem auth,
#                                    # mas o provider exige valor nao-vazio

# Perfis opcionais do stack unificado:
# COMPOSE_PROFILES=tls,embeddings-cpu
#   tls            -> habilita o Caddy com TLS automatico
#   embeddings-cpu -> backend de embedding em CPU (TEI, e5-large)
#   embeddings-gpu -> backend em GPU (Infinity, e5-large); requer NVIDIA
#                     Container Toolkit no Docker engine. Para "preferir GPU
#                     com CPU de prontidao": COMPOSE_PROFILES=embeddings-cpu,embeddings-gpu
