{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "High-level health overview: service up/down, queue freshness, MCP activity, indexed project inventory and recent error rates.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "MCP Server",
      "url": "/d/wqm-mcp-server",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "MCP HTTP",
      "url": "/d/wqm-mcp-http",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "memexd Daemon",
      "url": "/d/wqm-memexd",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Qdrant",
      "url": "/d/wqm-qdrant",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "memexd Target Health",
      "description": "Prometheus scrape target health for the memexd job.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"memexd\"}",
          "legendFormat": "{{job}} @ {{instance}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "MCP Target Health",
      "description": "Prometheus scrape target health for the mcp job.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"mcp\"}",
          "legendFormat": "{{job}} @ {{instance}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Qdrant Target Health",
      "description": "Prometheus scrape target health for the qdrant job.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"qdrant\"}",
          "legendFormat": "{{job}} @ {{instance}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Oldest Pending Age by Target",
      "description": "Age in seconds of the oldest pending queue item per scrape target.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "wqm_queue_oldest_pending_age_seconds",
          "legendFormat": "{{job}} @ {{instance}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Stale Queue Items (total)",
      "description": "Combined number of stale lease items across all memexd scrape targets.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(memexd_unified_queue_stale_items) or vector(0)",
          "legendFormat": "total",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Active MCP Sessions by Target",
      "description": "Number of active MCP sessions per scrape target.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "wqm_mcp_session_count",
          "legendFormat": "{{job}} @ {{instance}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "MCP Tool Invocation Rate",
      "description": "Total MCP tool invocation rate across all tools.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(wqm_mcp_tool_invocations_total[2m]))",
          "legendFormat": "total invocations/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Queue Health Trend",
      "description": "Queue freshness signals over time: oldest pending age and stale lease items.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "wqm_queue_oldest_pending_age_seconds",
          "legendFormat": "oldest pending age",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(memexd_unified_queue_stale_items)",
          "legendFormat": "stale items",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent Error Rates",
      "description": "Error rates across the MCP server and HTTP transport.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tool) (rate(wqm_mcp_tool_invocations_total{status=\"error\"}[5m]))",
          "legendFormat": "{{tool}} errors",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tool, reason) (rate(wqm_mcp_daemon_fallback_total[5m]))",
          "legendFormat": "{{tool}} / {{reason}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (reason) (rate(wqm_mcp_http_auth_failures_total[5m]))",
          "legendFormat": "auth {{reason}}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(wqm_mcp_http_rate_limited_total[5m])",
          "legendFormat": "rate limit hits",
          "refId": "D"
        }
      ]
    },
    {
      "id": 10,
      "title": "Indexed Projects",
      "description": "Live indexed project inventory from memexd's SQLite state, including path, status flags, document counts, point counts and scan/activity timestamps.",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": true
          },
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 20000 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Last Scan" },
            "properties": [{ "id": "unit", "value": "dateTimeAsIso" }]
          },
          {
            "matcher": { "id": "byName", "options": "Last Activity" },
            "properties": [{ "id": "unit", "value": "dateTimeAsIso" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "Documents", "desc": true }
        ],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "watch_id",
            "mode": "outerTabular"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Metric": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "watch_id": true
            },
            "renameByName": {
              "Value": "Documents",
              "Value #A": "Documents",
              "Value #B": "Points",
              "Value #C": "Last Scan",
              "Value #D": "Last Activity",
              "tenant_id": "Project ID",
              "path": "Path",
              "enabled": "Enabled",
              "is_active": "Active",
              "is_paused": "Paused",
              "is_archived": "Archived",
              "is_worktree": "Worktree",
              "is_git_tracked": "Git Tracked"
            },
            "indexByName": {
              "Project ID": 0,
              "Path": 1,
              "Documents": 2,
              "Points": 3,
              "Last Scan": 4,
              "Last Activity": 5,
              "Enabled": 6,
              "Active": 7,
              "Paused": 8,
              "Archived": 9,
              "Worktree": 10,
              "Git Tracked": 11
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (watch_id, tenant_id, path, enabled, is_active, is_paused, is_archived, is_worktree, is_git_tracked) (memexd_indexed_project_tracked_files)",
          "legendFormat": "{{tenant_id}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (watch_id) (memexd_indexed_project_points)",
          "legendFormat": "{{watch_id}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (watch_id) (memexd_indexed_project_last_scan_seconds)",
          "legendFormat": "{{watch_id}}",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (watch_id) (memexd_indexed_project_last_activity_seconds)",
          "legendFormat": "{{watch_id}}",
          "refId": "D",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["wqm", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WQM — System Overview",
  "uid": "wqm-system",
  "version": 3
}
