{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "High-level health overview: service up/down, total queue depth, MCP tool invocation trend and recent error events.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "MCP Server",
      "url": "/d/wqm-claude-mcp",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "memexd Daemon",
      "url": "/d/wqm-memexd",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Qdrant",
      "url": "/d/wqm-qdrant",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Code Graph",
      "url": "/d/wqm-code-graph",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "State DB",
      "url": "/d/wqm-state-db",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "memexd",
      "description": "Prometheus scrape target health for the memexd job.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"memexd\"} or vector(0)",
          "legendFormat": "memexd",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "MCP Server",
      "description": "Prometheus scrape target health for the mcp job.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"mcp\"} or vector(0)",
          "legendFormat": "mcp",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Qdrant",
      "description": "Prometheus scrape target health for the qdrant job.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"qdrant\"} or vector(0)",
          "legendFormat": "qdrant",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Pending Queue Items",
      "description": "Sum of all pending items across the unified queue (wqm_memexd_unified_queue_depth{status=\"pending\"}).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(wqm_memexd_unified_queue_depth{status=\"pending\"}) or vector(0)",
          "legendFormat": "pending items",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active MCP Sessions",
      "description": "Number of active MCP sessions at the server level (wqm_mcp_session_count).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "wqm_mcp_session_count or vector(0)",
          "legendFormat": "sessions",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "MCP Tool Invocation Rate",
      "description": "Total MCP tool invocation rate across all tools — a sparkline view of system activity.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(wqm_mcp_tool_invocations_total[2m])) or vector(0)",
          "legendFormat": "total invocations/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Queue Depth Trend",
      "description": "Combined queue depth over time — an early warning signal for processing stalls.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(wqm_memexd_queue_depth{collection=~\"$collection\"}) or vector(0)",
          "legendFormat": "legacy queue",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(wqm_memexd_unified_queue_depth{status=\"pending\"}) or vector(0)",
          "legendFormat": "unified pending",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Recent Error Events",
      "description": "Table of recent error-rate values across all error counters. Non-zero rows indicate active problems.",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": {
            "displayMode": "color-background-solid",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }],
        "footer": { "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(sum by (error_type) (rate(wqm_memexd_ingestion_errors_total[5m])), \"source\", \"memexd ingestion ($1)\", \"error_type\", \"(.+)\")",
          "legendFormat": "ingestion {{error_type}}",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(sum by (watch_id) (rate(wqm_memexd_watch_errors_total[5m])), \"source\", \"watch ($1)\", \"watch_id\", \"(.+)\")",
          "legendFormat": "watch {{watch_id}}",
          "refId": "B",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(sum by (tool) (rate(wqm_mcp_tool_invocations_total{status=\"error\"}[5m])), \"source\", \"mcp tool ($1)\", \"tool\", \"(.+)\")",
          "legendFormat": "mcp {{tool}}",
          "refId": "C",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(sum by (tool, reason) (rate(wqm_mcp_daemon_fallback_total[5m])), \"source\", \"fallback ($1/$2)\", \"tool\", \"(.+)\")",
          "legendFormat": "fallback {{tool}} {{reason}}",
          "refId": "D",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "pattern": ".*" }
          }
        }
      ]
    },
    {
      "id": 9,
      "title": "Code Graph Nodes",
      "description": "Total nodes in the code relationship graph aggregated across all graph types (sum(wqm_memexd_graph_nodes)). Phase 1: only the code graph exists. Links to the Code Graph dashboard.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "mappings": [],
          "links": [
            { "title": "Open Code Graph dashboard", "url": "/d/wqm-code-graph", "targetBlank": false }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(wqm_memexd_graph_nodes) or vector(0)",
          "legendFormat": "graph nodes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "State DB File Size",
      "description": "On-disk size of the SQLite state database (wqm_memexd_state_db_size_bytes). Links to the State DB dashboard.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 524288000 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "mappings": [],
          "links": [
            { "title": "Open State DB dashboard", "url": "/d/wqm-state-db", "targetBlank": false }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "wqm_memexd_state_db_size_bytes or vector(0)",
          "legendFormat": "db size",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Queue Failure Heatmap by Item Type",
      "description": "Failure counts over time bucketed by queue item_type, derived from the wqm_memexd_unified_queue_items_total{result=\"failure\"} counter via increase(). This counter exposes item_type/op/result labels (no collection label), so failures are bucketed by item_type. The heatmap uses the series directly as rows (calculate=false) — no histogram_quantile, no le.",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "scaleDistribution": { "type": "linear" } }
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "steps": 64,
          "reverse": true,
          "fill": "dark-orange"
        },
        "yAxis": { "axisPlacement": "left", "unit": "short" },
        "cellGap": 1,
        "cellValues": {},
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": true },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (item_type) (increase(wqm_memexd_unified_queue_items_total{result=\"failure\"}[$__interval]))",
          "legendFormat": "{{item_type}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["wqm", "overview"],
  "templating": {
    "list": [
      {
        "name": "collection",
        "label": "Collection",
        "description": "Filter panels whose metric carries a collection label (legacy queue depth). Defaults to All.",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(wqm_memexd_queue_depth, collection)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WQM — System Overview",
  "uid": "wqm-system",
  "version": 1
}
