{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Code-relationship graph health: node/edge structure per tenant, edge-type distribution (CALLS/IMPORTS/USES_TYPE/CONTAINS), unresolved-stub pollution, ingest throughput, stub-resolver activity, and per-action query latency.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview — $tenant",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "none",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Total Edges",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(memexd_graph_edges{tenant_id=\"$tenant\"})", "legendFormat": "edges", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "none",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Total Nodes",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(memexd_graph_nodes{tenant_id=\"$tenant\"})", "legendFormat": "nodes", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green",  "value": 0.5 }
            ]
          },
          "unit": "none",
          "decimals": 2,
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "description": "Edges divided by nodes. A near-zero ratio means the graph is dangling (edges not built) — the symptom this dashboard exists to catch. Healthy code graphs are typically > 0.5.",
      "title": "Edges / Node",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(memexd_graph_edges{tenant_id=\"$tenant\"}) / clamp_min(sum(memexd_graph_nodes{tenant_id=\"$tenant\"}), 1)", "legendFormat": "ratio", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 500 }
            ]
          },
          "unit": "none",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "description": "Internal unresolved stubs: name-only targets whose symbol HAS a real in-project definition but were not yet repointed by the resolver. External/stdlib refs with no project definition are EXCLUDED (they never resolve by design). A non-zero value means the resolver is behind or hit ambiguous names; steady state should be ~0.",
      "title": "Unresolved Stubs (internal)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(memexd_graph_unresolved_stubs{tenant_id=\"$tenant\"})", "legendFormat": "stubs", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "unit": "none",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "CALLS Edges",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(memexd_graph_edges{tenant_id=\"$tenant\", edge_type=\"CALLS\"})", "legendFormat": "CALLS", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "unit": "none",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "IMPORTS Edges",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(memexd_graph_edges{tenant_id=\"$tenant\", edge_type=\"IMPORTS\"})", "legendFormat": "IMPORTS", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Edge Structure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CALLS" },     "properties": [ { "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "IMPORTS" },   "properties": [ { "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "USES_TYPE" }, "properties": [ { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "CONTAINS" },  "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Edges by Type",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "memexd_graph_edges{tenant_id=\"$tenant\"}", "legendFormat": "{{edge_type}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" } },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 6 },
      "id": 11,
      "options": { "pieType": "donut", "tooltip": { "mode": "single" }, "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Edge Type Distribution",
      "type": "piechart",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (edge_type) (memexd_graph_edges{tenant_id=\"$tenant\"})", "legendFormat": "{{edge_type}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Node Structure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 15 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "title": "Nodes by Type",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "memexd_graph_nodes{tenant_id=\"$tenant\"}", "legendFormat": "{{node_type}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" } },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 15 },
      "id": 13,
      "options": { "pieType": "donut", "tooltip": { "mode": "single" }, "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Node Type Distribution",
      "type": "piechart",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (node_type) (memexd_graph_nodes{tenant_id=\"$tenant\"})", "legendFormat": "{{node_type}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Throughput & Resolver Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }, "unit": "cps" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Edges Ingested / s by Type",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(memexd_graph_edges_ingested_total{tenant_id=\"$tenant\"}[5m])", "legendFormat": "{{edge_type}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }, "unit": "cps" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 21,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "description": "Rate at which the 120s background stub-resolver repoints name-only stub edges to real project symbols. Spikes after (re)indexing, then settles toward zero as the graph converges.",
      "title": "Stub Repoints / s",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(memexd_graph_stub_resolved_total{tenant_id=\"$tenant\"}[5m])", "legendFormat": "repoints/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-RdYlGr" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "gradientMode": "scheme" }, "unit": "none" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 22,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "description": "Internal unresolved stub count over time (external/stdlib refs excluded). Should trend to ~0 as the resolver runs; a persistent non-zero value means resolvable in-project names the resolver hasn't repointed (e.g. ambiguous same-name symbols).",
      "title": "Unresolved Stubs (internal, trend)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(memexd_graph_unresolved_stubs{tenant_id=\"$tenant\"})", "legendFormat": "unresolved stubs", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Query Latency (GraphService RPC)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "id": 30,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } },
      "description": "p95 latency per graph query action (PageRank, ImpactAnalysis, QueryRelated, etc.), reused from the generic gRPC metrics layer (memexd_grpc_request_duration_seconds, service=GraphService). Not tenant-scoped.",
      "title": "Graph Query p95 Latency by Action",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (le, method) (rate(memexd_grpc_request_duration_seconds_bucket{service=\"GraphService\"}[5m])))", "legendFormat": "{{method}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["memexd", "graph"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "query_result(memexd_indexed_project_tracked_files)",
        "hide": 0,
        "includeAll": false,
        "label": "Project",
        "multi": false,
        "name": "tenant",
        "options": [],
        "query": { "query": "query_result(memexd_indexed_project_tracked_files)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "/path=\"[^\"]*\\/(?<text>[^\"\\/]+)\".*tenant_id=\"(?<value>[^\"]+)\"/",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Code Graph Observability",
  "uid": "memexd-code-graph",
  "version": 3
}
