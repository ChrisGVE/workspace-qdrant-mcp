{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "State DB (SQLite) health: schema/size/WAL, per-table row counts, queue depth and sub-status, processing timings, search events, and maintenance/vacuum.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "WQM Dashboards",
      "type": "dashboards",
      "tags": ["wqm"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "State DB Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Schema Version",
      "description": "State DB schema migration version (wqm_memexd_state_db_schema_version).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "none", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(wqm_memexd_state_db_schema_version)", "legendFormat": "schema", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "DB File Size",
      "description": "State DB logical size in bytes (wqm_memexd_state_db_size_bytes = page_count * page_size).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(wqm_memexd_state_db_size_bytes)", "legendFormat": "db size", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "WAL File Size",
      "description": "Approximate state DB WAL file size in bytes (wqm_memexd_state_db_wal_size_bytes).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "yellow", "value": 67108864 }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(wqm_memexd_state_db_wal_size_bytes)", "legendFormat": "wal size", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "WAL Checkpoint Lag (frames)",
      "description": "WAL frames not yet checkpointed into the main DB file (wqm_memexd_state_db_wal_frames_pending). High values indicate checkpoint pressure.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(wqm_memexd_state_db_wal_frames_pending)", "legendFormat": "pending frames", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Queue Depth (pending)",
      "description": "Pending unified-queue items (wqm_memexd_unified_queue_depth{status=\"pending\"}).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(wqm_memexd_unified_queue_depth{status=\"pending\"})", "legendFormat": "pending", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "Stale Queue Items",
      "description": "Unified-queue items past their lease/stale threshold (wqm_memexd_unified_queue_stale_items).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 50 }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(wqm_memexd_unified_queue_stale_items)", "legendFormat": "stale", "refId": "A" }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Table Row Counts",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 7,
      "title": "Table Row Counts (canonical 14 tables)",
      "description": "Row counts per canonical state-DB table (wqm_memexd_state_db_table_rows{table}). Bounded 14-table set.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "continuous-GrYlRd" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "wqm_memexd_state_db_table_rows{table=~\"unified_queue|dead_letter_queue|tracked_files|indexed_content|qdrant_chunks|graph_nodes|graph_edges|metrics_history|code_lines|watch_folders|keywords|search_events|processing_timings|resolution_events\"}",
          "legendFormat": "{{table}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Queue Depth by Status/Type",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 8,
      "title": "Queue Depth by Status",
      "description": "Unified-queue depth grouped by status (wqm_memexd_unified_queue_depth).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true, "stacking": { "mode": "normal", "group": "A" } }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "last"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (status) (wqm_memexd_unified_queue_depth)", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "title": "Queue Depth by Type",
      "description": "Unified-queue depth grouped by item_type (wqm_memexd_unified_queue_depth).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true, "stacking": { "mode": "normal", "group": "A" } }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "last"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (item_type) (wqm_memexd_unified_queue_depth)", "legendFormat": "{{item_type}}", "refId": "A" }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "Queue Sub-status",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 10,
      "title": "Qdrant Destination Status",
      "description": "Unified-queue items by Qdrant destination status (wqm_memexd_unified_queue_qdrant_status).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "last"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (qdrant_status) (wqm_memexd_unified_queue_qdrant_status)", "legendFormat": "{{qdrant_status}}", "refId": "A" }
      ]
    },
    {
      "id": 11,
      "title": "Search Index Destination Status",
      "description": "Unified-queue items by search-index destination status (wqm_memexd_unified_queue_search_status).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "last"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (search_status) (wqm_memexd_unified_queue_search_status)", "legendFormat": "{{search_status}}", "refId": "A" }
      ]
    },
    {
      "id": 104,
      "type": "row",
      "title": "Processing Timings",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "id": 12,
      "title": "Processing Phase Latency (P50 / P95 / P99)",
      "description": "Per-phase processing latency (wqm_memexd_processing_phase_duration_seconds) by canonical phase.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (phase, le) (rate(wqm_memexd_processing_phase_duration_seconds_bucket{collection=~\"$collection\"}[5m])))", "legendFormat": "p50 {{phase}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (phase, le) (rate(wqm_memexd_processing_phase_duration_seconds_bucket{collection=~\"$collection\"}[5m])))", "legendFormat": "p95 {{phase}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (phase, le) (rate(wqm_memexd_processing_phase_duration_seconds_bucket{collection=~\"$collection\"}[5m])))", "legendFormat": "p99 {{phase}}", "refId": "C" }
      ]
    },
    {
      "id": 13,
      "title": "Processing Volume by Phase",
      "description": "Items processed per second per phase (wqm_memexd_processing_phase_items_total).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (phase) (rate(wqm_memexd_processing_phase_items_total[5m]))", "legendFormat": "{{phase}}", "refId": "A" }
      ]
    },
    {
      "id": 105,
      "type": "row",
      "title": "Search Events",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }
    },
    {
      "id": 14,
      "title": "Search Request Rate",
      "description": "Search requests per second by collection (rate of wqm_memexd_search_duration_seconds_count).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (collection) (rate(wqm_memexd_search_duration_seconds_count{collection=~\"$collection\"}[5m]))", "legendFormat": "{{collection}}", "refId": "A" }
      ]
    },
    {
      "id": 15,
      "title": "Search Result Count (P50 / P95)",
      "description": "Distribution of results returned per search (wqm_memexd_search_result_count).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never", "spanNulls": true }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(wqm_memexd_search_result_count_bucket{collection=~\"$collection\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(wqm_memexd_search_result_count_bucket{collection=~\"$collection\"}[5m])))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "id": 106,
      "type": "row",
      "title": "Maintenance / Vacuum",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }
    },
    {
      "id": 16,
      "title": "Last Vacuum Age",
      "description": "Time since the last state-DB VACUUM (now - wqm_memexd_state_db_last_vacuum_timestamp_seconds). Renders 'No data' until the first VACUUM runs (never vacuumed).",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 604800 }, { "color": "red", "value": 2592000 }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "time() - max(wqm_memexd_state_db_last_vacuum_timestamp_seconds)", "legendFormat": "age", "refId": "A" }
      ]
    },
    {
      "id": 17,
      "title": "Free Page Count",
      "description": "Free pages in the state-DB freelist (wqm_memexd_state_db_free_pages). High values suggest a VACUUM would reclaim space.",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 5000 }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(wqm_memexd_state_db_free_pages)", "legendFormat": "free pages", "refId": "A" }
      ]
    },
    {
      "id": 18,
      "title": "Integrity Check Status",
      "description": "Result of the most recent PRAGMA quick_check (wqm_memexd_state_db_integrity_ok): 1 = ok, 0 = corruption.",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(wqm_memexd_state_db_integrity_ok)", "legendFormat": "integrity", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["wqm", "state-db"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "collection",
        "type": "custom",
        "label": "Collection",
        "query": "projects,libraries,rules,scratchpad",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "projects", "value": "projects", "selected": false },
          { "text": "libraries", "value": "libraries", "selected": false },
          { "text": "rules", "value": "rules", "selected": false },
          { "text": "scratchpad", "value": "scratchpad", "selected": false }
        ],
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WQM — State DB",
  "uid": "wqm-state-db",
  "version": 1
}
