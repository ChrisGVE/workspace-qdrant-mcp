{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Code knowledge-graph observability: graph state, coverage by type, growth, algorithm performance, ingestion health, and SQLite backend health. Scoped to graph_type=code.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "WQM Dashboards",
      "type": "dashboards",
      "tags": ["wqm"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Graph State",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Graph DB Up",
      "description": "Whether the graph backend is exporting metrics. Derived from presence of wqm_memexd_graph_schema_version for the selected graph_type/backend (no dedicated up metric).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Down", "color": "red" } } },
            { "type": "range", "options": { "from": 1, "to": 1000000, "result": { "text": "Up", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(wqm_memexd_graph_schema_version{graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "up",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Nodes",
      "description": "Total graph nodes (wqm_memexd_graph_nodes) for the selected tenant(s)/graph_type/backend.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(wqm_memexd_graph_nodes{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "nodes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Edges",
      "description": "Total graph edges (wqm_memexd_graph_edges) for the selected tenant(s)/graph_type/backend.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(wqm_memexd_graph_edges{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "edges",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Schema Version",
      "description": "Graph schema migration version (wqm_memexd_graph_schema_version).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(wqm_memexd_graph_schema_version{graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "schema",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Orphaned Nodes",
      "description": "Graph nodes with no incident edges (wqm_memexd_graph_orphaned_nodes). Non-zero may indicate incomplete edge extraction.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(wqm_memexd_graph_orphaned_nodes{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "orphaned",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Graph DB Size",
      "description": "On-disk graph database size in bytes (wqm_memexd_graph_db_size_bytes).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(wqm_memexd_graph_db_size_bytes{graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "size",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Coverage by Type",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 7,
      "title": "Node Distribution by Type",
      "description": "Graph node counts grouped by node_type (wqm_memexd_graph_nodes_by_type).",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (node_type) (wqm_memexd_graph_nodes_by_type{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "{{node_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Edge Distribution by Type",
      "description": "Graph edge counts grouped by edge_type (wqm_memexd_graph_edges_by_type).",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (edge_type) (wqm_memexd_graph_edges_by_type{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "{{edge_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Growth Trend",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 9,
      "title": "Node Count Growth",
      "description": "Total graph nodes over time (wqm_memexd_graph_nodes).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(wqm_memexd_graph_nodes{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "nodes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Edge Count Growth",
      "description": "Total graph edges over time (wqm_memexd_graph_edges).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(wqm_memexd_graph_edges{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "edges",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "Algorithm Performance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 11,
      "title": "Algorithm & Extraction Duration (P50 / P95)",
      "description": "Graph algorithm run duration by algorithm (wqm_memexd_graph_algorithm_duration_seconds) plus graph extraction duration by layer (wqm_memexd_graph_extract_duration_seconds; extract_duration carries the layer label).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (algorithm, le) (rate(wqm_memexd_graph_algorithm_duration_seconds_bucket{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m])))",
          "legendFormat": "p50 algo={{algorithm}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (algorithm, le) (rate(wqm_memexd_graph_algorithm_duration_seconds_bucket{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m])))",
          "legendFormat": "p95 algo={{algorithm}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (layer, le) (rate(wqm_memexd_graph_extract_duration_seconds_bucket{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m])))",
          "legendFormat": "p95 extract layer={{layer}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "Last Algorithm Run",
      "description": "Most recent run timestamp per algorithm (wqm_memexd_graph_algorithm_last_run_timestamp_seconds).",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "dateTimeAsIso", "custom": { "align": "auto" }, "mappings": [] },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "unit", "value": "dateTimeFromNow" }]
          }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "wqm_memexd_graph_algorithm_last_run_timestamp_seconds{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"}",
          "legendFormat": "{{algorithm}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "Time": true, "job": true, "instance": true },
            "renameByName": { "algorithm": "Algorithm", "tenant_id": "Tenant", "Value": "Last Run" }
          }
        }
      ]
    },
    {
      "id": 104,
      "type": "row",
      "title": "Ingestion Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "id": 13,
      "title": "Graph Upsert Rate",
      "description": "Graph node/edge upserts per second (wqm_memexd_graph_upsert_nodes_total, wqm_memexd_graph_upsert_edges_total).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(wqm_memexd_graph_upsert_nodes_total{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m]))",
          "legendFormat": "nodes/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(wqm_memexd_graph_upsert_edges_total{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m]))",
          "legendFormat": "edges/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 14,
      "title": "Ingestion Errors",
      "description": "Graph ingestion error rate (wqm_memexd_graph_ingest_errors_total). Should be zero in steady state.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 12, "showPoints": "never", "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(wqm_memexd_graph_ingest_errors_total{tenant_id=~\"$tenant\",graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 105,
      "type": "row",
      "title": "SQLite Backend Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }
    },
    {
      "id": 15,
      "title": "Graph DB File Size",
      "description": "SQLite graph database file size over time (wqm_memexd_graph_db_size_bytes).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 12, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(wqm_memexd_graph_db_size_bytes{graph_type=\"$graph_type\",backend=\"$graph_backend\"})",
          "legendFormat": "graph.db size",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "Graph Query Latency (P50 / P95)",
      "description": "PENDING: graph query-latency instrumentation (wqm_memexd_graph_query_duration_seconds) is not yet shipped — this panel renders 'No data' until that metric lands. Panel is forward-compatible.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(wqm_memexd_graph_query_duration_seconds_bucket{graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(wqm_memexd_graph_query_duration_seconds_bucket{graph_type=\"$graph_type\",backend=\"$graph_backend\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "60s",
  "schemaVersion": 39,
  "tags": ["wqm", "graph"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
