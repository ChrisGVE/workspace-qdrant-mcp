{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Rust daemon (memexd) health: queue depth, processing throughput, processing latency, sessions, watch errors and uptime.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Daemon Uptime",
      "description": "memexd process uptime in seconds (wqm_memexd_uptime_seconds).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 300 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(wqm_memexd_uptime_seconds)",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Sessions",
      "description": "Number of active daemon sessions across all projects (wqm_memexd_active_sessions).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(wqm_memexd_active_sessions)",
          "legendFormat": "active sessions",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Watches in Backoff",
      "description": "Number of file-system watches currently in exponential backoff (wqm_memexd_watches_in_backoff). Any non-zero value warrants investigation.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(wqm_memexd_watches_in_backoff)",
          "legendFormat": "backoff watches",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Oldest Pending Queue Item Age",
      "description": "Age in seconds of the oldest pending item in the unified queue (wqm_memexd_queue_oldest_pending_age_seconds). High values indicate processing stalls.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "wqm_memexd_queue_oldest_pending_age_seconds",
          "legendFormat": "oldest pending",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Queue Depth by Priority",
      "description": "Current queue depth broken down by priority and collection (wqm_memexd_queue_depth).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (priority) (wqm_memexd_queue_depth{collection=~\"$collection\"})",
          "legendFormat": "priority={{priority}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Queue Processing Throughput",
      "description": "Items processed per second by priority and status (wqm_memexd_queue_items_processed_total).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (priority) (rate(wqm_memexd_queue_items_processed_total{status=\"success\"}[2m]))",
          "legendFormat": "success priority={{priority}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (priority) (rate(wqm_memexd_queue_items_processed_total{status=\"failure\"}[2m]))",
          "legendFormat": "failure priority={{priority}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Queue Processing Latency (P50 / P95 / P99)",
      "description": "Queue item processing time distribution (wqm_memexd_queue_processing_time_seconds).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (priority, le) (rate(wqm_memexd_queue_processing_time_seconds_bucket[5m])))",
          "legendFormat": "p50 priority={{priority}}",
          "exemplar": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (priority, le) (rate(wqm_memexd_queue_processing_time_seconds_bucket[5m])))",
          "legendFormat": "p95 priority={{priority}}",
          "exemplar": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (priority, le) (rate(wqm_memexd_queue_processing_time_seconds_bucket[5m])))",
          "legendFormat": "p99 priority={{priority}}",
          "exemplar": true,
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Ingestion and Watch Error Rates",
      "description": "Rate of ingestion errors (wqm_memexd_ingestion_errors_total) and watch errors (wqm_memexd_watch_errors_total). Both should be zero in steady state.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (error_type) (rate(wqm_memexd_ingestion_errors_total[2m]))",
          "legendFormat": "ingest {{error_type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (watch_id) (rate(wqm_memexd_watch_errors_total[2m]))",
          "legendFormat": "watch {{watch_id}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Unified Queue Depth by Type and Status",
      "description": "Unified queue item counts broken down by item_type and status (wqm_memexd_unified_queue_depth).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (item_type, status) (wqm_memexd_unified_queue_depth)",
          "legendFormat": "{{item_type}} / {{status}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(wqm_memexd_unified_queue_depth)",
          "legendFormat": "total depth",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "title": "Embedding Provider Performance",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "panels": []
    },
    {
      "id": 11,
      "title": "Embedding Request Rate",
      "description": "Embedding provider request rate by provider and HTTP status class (wqm_memexd_embedding_provider_requests_total). status_class is one of 2xx/4xx/5xx/error.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (provider, status_class) (rate(wqm_memexd_embedding_provider_requests_total[2m]))",
          "legendFormat": "{{provider}} {{status_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Embedding Error Rate",
      "description": "Embedding provider error rate by provider (4xx/5xx/transport-error status classes of wqm_memexd_embedding_provider_requests_total). Should be near zero in steady state.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 12, "showPoints": "never", "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (provider) (rate(wqm_memexd_embedding_provider_requests_total{status_class=~\"4xx|5xx|error\"}[2m]))",
          "legendFormat": "{{provider}} errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Embedding Latency (P50 / P95 / P99)",
      "description": "Embedding provider request latency distribution by provider (wqm_memexd_embedding_provider_latency_seconds).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never", "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (provider, le) (rate(wqm_memexd_embedding_provider_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{provider}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(wqm_memexd_embedding_provider_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{provider}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (provider, le) (rate(wqm_memexd_embedding_provider_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{provider}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 14,
      "title": "Embedding Rate-Limit Waits",
      "description": "Rate of provider rate-limit backoff waits by provider (wqm_memexd_embedding_provider_rate_limit_waits_total). Non-zero indicates the provider is throttling requests.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 12, "showPoints": "never", "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (provider) (rate(wqm_memexd_embedding_provider_rate_limit_waits_total[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "Per-Operation Queue Breakdown",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "panels": []
    },
    {
      "id": 16,
      "title": "Queue Throughput by Operation",
      "description": "Processed-item rate by queue operation (op label of wqm_memexd_unified_queue_items_total). Filtered by the $operation variable. op is one of add/update/delete/scan/rename/uplift/reset/reembed.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (op) (rate(wqm_memexd_unified_queue_items_total{op=~\"$operation\"}[2m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "title": "Queue Failure Rate by Operation",
      "description": "Failed-item rate by queue operation (wqm_memexd_unified_queue_items_total{result=\"failure\"}). Filtered by the $operation variable. Should be near zero in steady state.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 12, "showPoints": "never", "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (op) (rate(wqm_memexd_unified_queue_items_total{op=~\"$operation\",result=\"failure\"}[2m]))",
          "legendFormat": "{{op}} failures",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["wqm", "memexd"],
  "templating": {
    "list": [
      {
        "name": "collection",
        "label": "Collection",
        "description": "Filter panels whose metric carries a collection label (queue depth by priority). Defaults to All.",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(wqm_memexd_queue_depth, collection)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "multi": true,
