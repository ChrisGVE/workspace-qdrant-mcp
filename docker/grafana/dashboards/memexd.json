{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Rust daemon (memexd) operations: queue depth, throughput, embedding latency, gRPC traffic, ingestion errors, indexed projects.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "System Overview", "url": "/d/wqm-system", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "MCP Server", "url": "/d/wqm-mcp-server", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Qdrant", "url": "/d/wqm-qdrant", "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Target Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"memexd\"}", "refId": "A" }]
    },
    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "green", "value": 60 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(memexd_uptime_seconds)", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "Queue depth (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(memexd_unified_queue_depth) or vector(0)", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Oldest pending age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 300 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "wqm_queue_oldest_pending_age_seconds", "refId": "A" }]
    },
    {
      "id": 5,
      "title": "Stale items",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(memexd_unified_queue_stale_items) or vector(0)", "refId": "A" }]
    },
    {
      "id": 6,
      "title": "Ingestion errors (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(memexd_ingestion_errors_total[1h])) or vector(0)", "refId": "A" }]
    },
    {
      "id": 7,
      "title": "Items processed (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(memexd_queue_items_processed_total[24h])) or vector(0)", "refId": "A" }]
    },
    {
      "id": 8,
      "title": "Stale items (alert if > 0)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(memexd_unified_queue_stale_items)", "refId": "A" }]
    },

    { "id": 100, "type": "row", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }, "title": "Queue", "collapsed": false },

    {
      "id": 10,
      "title": "Unified queue depth — by item_type & status",
      "description": "Live snapshot of items in unified_queue. Sustained growth in pending = ingestion can't keep up.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (item_type, status) (memexd_unified_queue_depth)",
        "legendFormat": "{{item_type}} / {{status}}",
        "refId": "A"
      }]
    },
    {
      "id": 11,
      "title": "Enqueue vs dequeue rate (5m)",
      "description": "Producers vs consumers. Diverging lines = backpressure.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (source) (rate(memexd_unified_queue_enqueues_total[5m]))",
          "legendFormat": "enqueue / {{source}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (item_type) (rate(memexd_unified_queue_dequeues_total[5m]))",
          "legendFormat": "dequeue / {{item_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "title": "Items processed — by priority & status (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (priority, status) (rate(memexd_queue_items_processed_total[5m]))",
        "legendFormat": "{{priority}} / {{status}}",
        "refId": "A"
      }]
    },
    {
      "id": 13,
      "title": "Queue processing time — p50 / p95 / p99",
      "description": "Distribution of per-item processing latency from the unified queue.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (item_type, le) (rate(memexd_unified_queue_processing_time_seconds_bucket[5m])))", "legendFormat": "p50 {{item_type}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (item_type, le) (rate(memexd_unified_queue_processing_time_seconds_bucket[5m])))", "legendFormat": "p95 {{item_type}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (item_type, le) (rate(memexd_unified_queue_processing_time_seconds_bucket[5m])))", "legendFormat": "p99 {{item_type}}", "refId": "C" }
      ]
    },

    { "id": 200, "type": "row", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }, "title": "Embedding", "collapsed": false },

    {
      "id": 20,
      "title": "Embedding duration — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (model, le) (rate(memexd_embedding_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{model}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (model, le) (rate(memexd_embedding_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{model}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (model, le) (rate(memexd_embedding_duration_seconds_bucket[5m])))", "legendFormat": "p99 {{model}}", "refId": "C" }
      ]
    },
    {
      "id": 21,
      "title": "Embedding batch size — avg (5m) & p99",
      "description": "Items per embedding call. Larger batches → better throughput but higher tail latency.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(memexd_embedding_batch_size_sum[5m])) / clamp_min(sum by (model) (rate(memexd_embedding_batch_size_count[5m])), 1)",
          "legendFormat": "avg {{model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (model, le) (rate(memexd_embedding_batch_size_bucket[5m])))",
          "legendFormat": "p99 {{model}}",
          "refId": "B"
        }
      ]
    },

    { "id": 300, "type": "row", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 }, "title": "gRPC", "collapsed": false },

    {
      "id": 30,
      "title": "gRPC request rate (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (service, method, status) (rate(memexd_grpc_requests_total[5m]))",
        "legendFormat": "{{service}}/{{method}} ({{status}})",
        "refId": "A"
      }]
    },
    {
      "id": 31,
      "title": "gRPC duration — p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.99, sum by (service, method, le) (rate(memexd_grpc_request_duration_seconds_bucket[5m])))",
        "legendFormat": "p99 {{service}}/{{method}}",
        "refId": "A"
      }]
    },

    { "id": 400, "type": "row", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 }, "title": "Errors & inventory", "collapsed": false },

    {
      "id": 40,
      "title": "Ingestion errors — by type (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "lineInterpolation": "linear", "fillOpacity": 80, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (error_type) (rate(memexd_ingestion_errors_total[5m]))",
        "legendFormat": "{{error_type}}",
        "refId": "A"
      }]
    },
    {
      "id": 41,
      "title": "Indexed projects",
      "description": "Every watch_folder the daemon tracks, with point count and last activity. Pulled from memexd_indexed_project_* gauges.",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [{ "id": "displayName", "value": "points" }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }] },
          { "matcher": { "id": "byName", "options": "Value #C" }, "properties": [{ "id": "displayName", "value": "tracked files" }] },
          { "matcher": { "id": "byName", "options": "Value #D" }, "properties": [{ "id": "displayName", "value": "last scan" }, { "id": "unit", "value": "dateTimeFromNow" }] },
          { "matcher": { "id": "byName", "options": "Value #E" }, "properties": [{ "id": "displayName", "value": "last activity" }, { "id": "unit", "value": "dateTimeFromNow" }] }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (watch_id, tenant_id, path, is_active, is_worktree) (memexd_indexed_project_points)",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (watch_id) (memexd_indexed_project_points)",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (watch_id) (memexd_indexed_project_tracked_files)",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1000 * max by (watch_id) (memexd_indexed_project_last_scan_seconds)",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1000 * max by (watch_id) (memexd_indexed_project_last_activity_seconds)",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "indexByName": {}
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["wqm", "memexd"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "WQM — memexd Daemon",
  "uid": "wqm-memexd",
  "version": 2,
  "weekStart": ""
}
