# syntax=docker/dockerfile:1.7
# Multi-stage, multi-arch Dockerfile for the TypeScript MCP server.
#
# Build:
#   docker buildx build --platform linux/amd64,linux/arm64 \
#     -f docker/Dockerfile.mcp -t mcp:latest --push .
#
# Single-arch local test (fast):
#   docker buildx build --platform linux/amd64 \
#     -f docker/Dockerfile.mcp -t mcp:test --load .
#
# Entry point: dist/index.js  (package.json "main" field)
#
# Transports:
#   stdio  — default (Claude Desktop, `claude mcp ...`)
#   http   — set MCP_SERVER_MODE=http to bind StreamableHTTPServerTransport on
#            MCP_HTTP_PORT (default 6335). Required for Docker deployments.
#
# Relevant environment variables:
#   MCP_SERVER_MODE       stdio | http                      (default: stdio)
#   MCP_HTTP_HOST         Listen host                       (default: 127.0.0.1)
#   MCP_HTTP_PORT         Listen port                       (default: 6335)
#   MCP_HTTP_PATH         Request path                      (default: /mcp)
#   MCP_HTTP_TOKEN        Bearer secret (required in http mode)
#   MCP_HTTP_RATE_LIMIT   Requests/min per IP               (default: 100)
#   MCP_HTTP_CORS_ORIGINS Comma-separated allowed origins   (default: none)
#   MCP_HTTP_TLS_CERT     PEM cert path — enables native TLS when set
#   MCP_HTTP_TLS_KEY      PEM key path  — enables native TLS when set
#   MCP_METRICS_PORT      Prometheus /metrics port          (default: 9092)
#   QDRANT_URL            Qdrant endpoint
#   WQM_DAEMON_ENDPOINT   gRPC address of memexd
#
# Ports:
#   6335 — MCP HTTP transport (only bound when MCP_SERVER_MODE=http)
#   9092 — Prometheus /metrics (bound when MCP_SERVER_MODE=http)
#
# A HEALTHCHECK is attached below against /healthz on the MCP HTTP port; it
# only succeeds when MCP_SERVER_MODE=http. stdio-mode deployments should
# disable the health check at run time (`docker run --no-healthcheck`).

ARG NODE_VERSION=20
ARG BUILDKIT_INLINE_CACHE=1

# ─────────────────────────────────────────────
# Stage 1: Build
# node:20-bookworm supplies the full Debian toolchain required to compile native
# addons (better-sqlite3 uses node-gyp → gcc, python3, make).
# ─────────────────────────────────────────────
FROM node:${NODE_VERSION}-bookworm AS builder

# Native-addon build dependencies.
# python3 + make + g++ are required by node-gyp (better-sqlite3).
# git is required by scripts/generate-build-info.ts (git rev-list --count HEAD).
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        make \
        g++ \
        git \
    && rm -rf /var/lib/apt/lists/*

# Mirror the real source-tree layout so that generate-config-defaults.ts can
# resolve PROJECT_ROOT correctly via:
#   resolve(__dirname, '..', '..', '..', '..')
# __dirname = /build/src/typescript/mcp-server/scripts
# PROJECT_ROOT resolves to /build
WORKDIR /build/src/typescript/mcp-server

# ── Dependency layer (cached until package*.json changes) ──
COPY src/typescript/mcp-server/package.json \
     src/typescript/mcp-server/package-lock.json ./

# --mount=type=cache keeps the npm package cache across builds.
# npm ci installs all deps (including devDependencies needed for tsc + tsx).
RUN --mount=type=cache,target=/root/.npm,sharing=locked \
    npm ci

# ── Source copy (invalidates when source changes; dep layer above stays cached) ──
# The assets directory must be present at /build/assets/ so generate-config-defaults.ts
# can load assets/default_configuration.yaml via PROJECT_ROOT resolution.
COPY src/typescript/mcp-server/ .
COPY assets/ /build/assets/

# Build: generates config defaults, build-info, compiles TypeScript, copies protos,
# and sets executable bit on entry-point scripts.
# git rev-list will gracefully fall back to build number "0000" if HEAD is absent.
RUN npm run build

# Remove all devDependencies; only production deps remain for the runtime stage.
RUN npm prune --production

# ─────────────────────────────────────────────
# Stage 2: Runtime
# node:20-alpine is minimal (~55 MB compressed).  Alpine includes the 'node'
# user (UID 1000) built into the official image, so no useradd is required.
# ─────────────────────────────────────────────
FROM node:${NODE_VERSION}-alpine AS runtime

# better-sqlite3 links against libstdc++ at runtime; alpine needs the compat
# library. wget is installed for the HEALTHCHECK below so the probe does not
# depend on curl or netcat availability.
RUN apk add --no-cache libstdc++ wget

LABEL org.opencontainers.image.title="workspace-qdrant-mcp" \
      org.opencontainers.image.description="TypeScript MCP server for workspace-qdrant" \
      org.opencontainers.image.version="0.1.3" \
      org.opencontainers.image.source="https://github.com/ChrisGVE/workspace-qdrant-mcp" \
      org.opencontainers.image.licenses="MIT"

WORKDIR /app

ENV NODE_ENV=production

# Copy compiled output and production node_modules from the build stage.
COPY --from=builder /build/src/typescript/mcp-server/dist ./dist
COPY --from=builder /build/src/typescript/mcp-server/node_modules ./node_modules
COPY --from=builder /build/src/typescript/mcp-server/package.json ./package.json

# Run as non-root. The 'node' user (UID 1000) is pre-created by the base image.
USER node

# MCP Streamable HTTP transport. Only bound when MCP_SERVER_MODE=http.
EXPOSE 6335
# Prometheus /metrics. Bound alongside the MCP transport in http mode.
EXPOSE 9092

# Health check against /healthz on the configured MCP HTTP port. Honours a
# runtime override of MCP_HTTP_PORT so custom compose configurations stay
# probeable.
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD sh -c 'wget -q -O- "http://127.0.0.1:${MCP_HTTP_PORT:-6335}/healthz" >/dev/null || exit 1'

# Entry point: package.json "main" → dist/index.js
# Mode selected at runtime via MCP_SERVER_MODE.
CMD ["node", "dist/index.js"]
