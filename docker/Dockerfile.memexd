# syntax=docker/dockerfile:1.7
# Multi-stage, multi-arch Dockerfile for the memexd daemon.
#
# Build: docker buildx build --platform linux/amd64,linux/arm64 \
#          -f docker/Dockerfile.memexd -t memexd:latest --push .
#
# Flag notes (verified against src/rust/daemon/memexd/src/startup.rs):
#   --grpc-port  : gRPC listen port (default 50051). Flag is "grpc-port", NOT "port".
#   --metrics-port: Prometheus metrics HTTP port. Optional; omitting disables the endpoint.
#   --foreground : Run in foreground (do not daemonize). Required in containers.
#   No --host flag exists; the daemon always binds to 0.0.0.0 internally.
#   Metrics endpoint: /metrics  Health endpoint: /health  (axum, metrics_server.rs)

ARG RUST_VERSION=1.90
ARG DEBIAN_CODENAME=bookworm
ARG ONNX_VERSION=1.23.2
ARG BUILDKIT_INLINE_CACHE=1

# Bundled LSP binary versions. Pinned so image builds are reproducible; bump
# these in a PR and the image is rebuilt with the new toolchain.
ARG RUST_ANALYZER_VERSION=2026-05-18
ARG GOPLS_VERSION=0.19.1

# Additional LSP binary versions — pinned for reproducible builds.
# Dart:  dart language-server --lsp covers both Dart and Flutter projects.
ARG DART_VERSION=3.7.2
# JDTLS (Eclipse JDT Language Server for Java) is pulled from the always-present
# `latest` snapshot, NOT a dated milestone — the milestone tarballs get pruned
# from download.eclipse.org (the old 1.45.0/202504251455 pin began 404ing and
# silently shipped an empty /opt/jdtls). Its bundles require Java 21, supplied by
# the Temurin JRE (temurin-download stage); the Debian default JRE is 17.

# ─────────────────────────────────────────────
# Stage 1: ONNX Runtime downloader
# Resolves the correct platform asset before the main build so the large
# tar download is cached as a separate layer independent of Rust source changes.
# ─────────────────────────────────────────────
FROM --platform=$BUILDPLATFORM debian:${DEBIAN_CODENAME}-slim AS onnx-download

ARG TARGETPLATFORM
ARG ONNX_VERSION

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Select correct asset for the target platform.
RUN set -eux; \
    case "${TARGETPLATFORM}" in \
        linux/amd64)  ONNX_ASSET="onnxruntime-linux-x64-static_lib-${ONNX_VERSION}.tgz" ;; \
        linux/arm64)  ONNX_ASSET="onnxruntime-linux-aarch64-static_lib-${ONNX_VERSION}.tgz" ;; \
        *) echo "Unsupported platform: ${TARGETPLATFORM}" && exit 1 ;; \
    esac; \
    mkdir -p /opt/onnxruntime; \
    curl --fail --silent --show-error --location \
        "https://github.com/supertone-inc/onnxruntime-build/releases/download/v${ONNX_VERSION}/${ONNX_ASSET}" \
        -o /tmp/onnx.tgz; \
    tar -xzf /tmp/onnx.tgz -C /opt/onnxruntime --strip-components=0; \
    rm /tmp/onnx.tgz

# ─────────────────────────────────────────────
# Stage 2: Rust build
# ─────────────────────────────────────────────
FROM rust:${RUST_VERSION}-${DEBIAN_CODENAME} AS builder

ARG TARGETPLATFORM
ARG ONNX_VERSION

# System dependencies for the build.
# git is required by daemon/memexd/build.rs (git rev-list --count HEAD → BUILD_NUMBER).
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        git \
        libprotobuf-dev \
        libssl-dev \
        pkg-config \
        protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*

# Copy ONNX Runtime static library from the downloader stage.
COPY --from=onnx-download /opt/onnxruntime /opt/onnxruntime

# Set ORT_LIB_LOCATION so ort-sys finds the static library at build time.
# The extracted archive places libs under a versioned subdirectory; find the lib dir.
RUN ORT_LIB=$(find /opt/onnxruntime -name "libonnxruntime*.a" | head -1 | xargs dirname); \
    echo "ORT_LIB_LOCATION=${ORT_LIB}" >> /etc/environment; \
    echo "Found ONNX lib at: ${ORT_LIB}"

ENV ORT_LIB_LOCATION=/opt/onnxruntime/lib

WORKDIR /build

# ── Dependency pre-fetch layer ──
# Copy only the workspace manifest files first.  This layer is cached as long as
# Cargo.toml / Cargo.lock do not change, even when application source changes.
COPY src/rust/Cargo.toml src/rust/Cargo.lock ./

# Copy every member Cargo.toml so the workspace resolver works without full source.
COPY src/rust/common/Cargo.toml                   common/
COPY src/rust/common-node/Cargo.toml              common-node/
COPY src/rust/cli/Cargo.toml                      cli/
COPY src/rust/daemon/core/Cargo.toml              daemon/core/
COPY src/rust/daemon/grpc/Cargo.toml              daemon/grpc/
COPY src/rust/daemon/memexd/Cargo.toml            daemon/memexd/
COPY src/rust/daemon/shared-test-utils/Cargo.toml daemon/shared-test-utils/
COPY src/rust/tools/registry-updater/Cargo.toml   tools/registry-updater/

# [patch.crates-io] in the workspace Cargo.toml points to patches/fastembed.
# Copy the entire patches/ tree so cargo fetch can resolve the patch source.
COPY src/rust/patches/                            patches/

# Create stub lib.rs / main.rs for every crate so `cargo fetch` resolves
# without needing the full source tree.  Also stub any `[[bench]]` entries
# declared in daemon/core/Cargo.toml — cargo validates bench paths even for
# `cargo fetch`, so missing files abort manifest parsing.
RUN set -eux; \
    for member in common common-node cli \
                  daemon/core daemon/grpc daemon/shared-test-utils \
                  tools/registry-updater; do \
        mkdir -p ${member}/src; \
        echo 'fn main() {}' > ${member}/src/main.rs 2>/dev/null || true; \
        echo '' > ${member}/src/lib.rs 2>/dev/null || true; \
    done; \
    mkdir -p daemon/memexd/src; \
    echo 'fn main() {}' > daemon/memexd/src/main.rs; \
    mkdir -p daemon/core/benches; \
    for bench in cross_platform_benchmarks queue_processor_bench \
                 stress_benchmarks example_benchmark qdrant_ingestion_bench \
                 fts5_search_bench graph_bench perf_extract_benchmarks \
                 perf_extract_comparison; do \
        echo 'fn main() {}' > daemon/core/benches/${bench}.rs; \
    done

# Build.rs for daemon/memexd uses git; provide a stub BUILD_NUMBER env fallback
# in case there is no git history inside the Docker build context.
COPY src/rust/daemon/memexd/build.rs daemon/memexd/build.rs

# Fetch all dependencies into the cargo registry cache.
# --mount=type=cache keeps the registry between builds.
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    cargo fetch --manifest-path /build/Cargo.toml

# ── Full source copy ──
# Invalidates when actual Rust source changes; dependency layers above remain cached.
COPY src/rust/ .

# Several Rust sources use `include_str!` with repository-root-relative paths
# (e.g. "../../../../../../patterns/...").  In this flat /build layout those
# resolve to the filesystem root.  Copy the referenced files there.
#   - common/src/yaml_defaults/mod.rs         → /assets/default_configuration.yaml
#   - daemon/core/src/patterns/comprehensive.rs → /assets/internal_configuration.yaml
#   - daemon/core/src/patterns/manager.rs     → /patterns/*.yaml
COPY assets/default_configuration.yaml /assets/default_configuration.yaml
COPY assets/internal_configuration.yaml /assets/internal_configuration.yaml
COPY patterns/ /patterns/

# Initialise a minimal git repo so build.rs can obtain BUILD_NUMBER.
# If a real .git directory is present in the build context it will be used instead.
# user.email / user.name must be configured inline — buildkit sandbox has neither.
RUN if [ ! -d .git ] && [ ! -f .git ]; then \
        git init -q; \
        git config user.email "build@docker.local"; \
        git config user.name "docker-build"; \
        git add -A; \
        git commit -q -m "docker-build"; \
    fi

# ── Compile ──
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/build/target,sharing=locked \
    ORT_LIB_LOCATION=/opt/onnxruntime/lib \
    cargo build --release --package memexd --package wqm-cli

# Copy the binaries out of the cache mount so the next stage can access them.
# wqm ships alongside memexd so `docker exec wqm-memexd wqm ...` runs against the
# daemon's own SQLite volume + local gRPC endpoint (correct data, no host wqm).
RUN --mount=type=cache,target=/build/target,sharing=locked \
    cp /build/target/release/memexd /usr/local/bin/memexd \
    && cp /build/target/release/wqm /usr/local/bin/wqm

# ─────────────────────────────────────────────
# Stage 2b: validate — local CI-parity gate (NOT part of the runtime image)
#
# Why this exists: a fast LOCAL pre-check. Work lands on `dev`/`main`, which DO
# get CI (`.github/workflows/ci.yml` runs on push/PR to `main`/`dev`), but the
# local Windows-native build breaks on a pre-existing winapi gate in
# storage/client.rs. This stage runs the SAME clippy + test suite as the CI
# `rust` job, inside the Linux builder, so any host can validate before pushing.
#
#   docker build --target validate -f docker/Dockerfile.memexd .
#   # or: scripts/validate.sh   (bash)   /   scripts/validate.ps1 (Windows)
#
# It is `FROM builder`, so it reuses the exact source layout, ONNX setup and
# dependency graph of the production build — zero drift. `runtime` does not
# reference it, so a normal image build never runs this stage.
# ─────────────────────────────────────────────
FROM builder AS validate

# The base rust image ships cargo/rustc but not the clippy component.
RUN rustup component add clippy

# The builder flattens src/rust to /build and copies only the two runtime
# YAML assets to /assets. Test code reaches additional repo-root assets via
# include_str! (e.g. tagging/taxonomy.rs → ../../../../../../assets/taxonomy.yaml,
# which resolves to /assets in this layout), so copy the whole assets tree for
# the clippy --tests / test compile to succeed.
COPY assets/ /assets/

# Gate = clippy (-D warnings, mirrors the CI `rust` job's lint step, compiling
# lib + bins + all test targets) + the production release build inherited from
# the `builder` stage. This is the reliable, high-value signal: lint-clean and
# the production binaries compile.
#
# The full `cargo test` suite is deliberately NOT run here. In this flattened
# single-container layout it is fragile and non-representative — the FTS5
# trigram text-search tests (text_search::{exact,regex}_search) and the
# timing-based adaptive_resources::idle_detection test fail for environment
# reasons, not real regressions. CI runs the suite at true parity on the push
# to `dev`/`main` (or the `dev → main` PR), checking it out in full with network.
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/build/target,sharing=locked \
    ORT_LIB_LOCATION=/opt/onnxruntime/lib \
    cargo clippy --lib --bins --tests -- -D warnings

# ─────────────────────────────────────────────
# Stage 3a: rust-analyzer binary download
# Ships as a single statically-linked release archive on GitHub. Downloaded
# in its own stage so the network fetch is cached independently of the Rust
# compilation and of the gopls toolchain.
# ─────────────────────────────────────────────
FROM debian:${DEBIAN_CODENAME}-slim AS rust-analyzer-download

ARG TARGETPLATFORM
ARG RUST_ANALYZER_VERSION

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gzip \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    mkdir -p /opt/lsp/bin; \
    case "${TARGETPLATFORM}" in \
        linux/amd64) RA_ASSET="rust-analyzer-x86_64-unknown-linux-gnu.gz" ;; \
        linux/arm64) RA_ASSET="rust-analyzer-aarch64-unknown-linux-gnu.gz" ;; \
        *) echo "Unsupported platform: ${TARGETPLATFORM}" && exit 1 ;; \
    esac; \
    curl --fail --silent --show-error --location \
        "https://github.com/rust-lang/rust-analyzer/releases/download/${RUST_ANALYZER_VERSION}/${RA_ASSET}" \
        -o /tmp/rust-analyzer.gz; \
    gunzip -c /tmp/rust-analyzer.gz > /opt/lsp/bin/rust-analyzer; \
    chmod +x /opt/lsp/bin/rust-analyzer; \
    rm /tmp/rust-analyzer.gz

# ─────────────────────────────────────────────
# Stage 3b: gopls build
# gopls is a Go module with no prebuilt release binaries; build it from source
# against the pinned version. The golang base image handles cross-compilation
# via GOOS/GOARCH automatically when invoked via buildx.
# ─────────────────────────────────────────────
FROM golang:1.24-${DEBIAN_CODENAME} AS gopls-build

ARG GOPLS_VERSION

# `GOBIN` controls where `go install` drops the resulting binary.
ENV GOBIN=/out
ENV CGO_ENABLED=0

RUN mkdir -p /out \
    && go install "golang.org/x/tools/gopls@v${GOPLS_VERSION}"

# ─────────────────────────────────────────────
# Stage 3c: Dart SDK download
# `dart language-server --lsp` is the canonical LSP entry-point for both
# Dart and Flutter projects (the Dart analyzer handles Flutter analysis).
# We download the full SDK because the dart binary loads snapshot files
# from the SDK at runtime; a lone binary would fail to start.
# ─────────────────────────────────────────────
FROM --platform=$BUILDPLATFORM debian:${DEBIAN_CODENAME}-slim AS dart-download

ARG TARGETPLATFORM
ARG DART_VERSION

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        unzip \
    && rm -rf /var/lib/apt/lists/*

# Best-effort: always create /opt/dart-sdk so the runtime COPY succeeds even if
# the download fails (the daemon gracefully handles an absent `dart` binary).
RUN set -ux; \
    mkdir -p /opt/dart-sdk/bin; \
    case "${TARGETPLATFORM}" in \
        linux/amd64) DART_ARCH="x64"   ;; \
        linux/arm64) DART_ARCH="arm64" ;; \
        *) DART_ARCH="" ;; \
    esac; \
    if [ -n "${DART_ARCH}" ] && curl --fail --silent --show-error --location \
        "https://storage.googleapis.com/dart-archive/channels/stable/release/${DART_VERSION}/sdk/dartsdk-linux-${DART_ARCH}-release.zip" \
        -o /tmp/dart-sdk.zip; then \
        unzip -q /tmp/dart-sdk.zip -d /opt && rm /tmp/dart-sdk.zip && chmod +x /opt/dart-sdk/bin/dart; \
    else \
        echo "WARNING: Dart SDK download failed (non-fatal) — Dart/Flutter LSP unavailable."; \
    fi

# ─────────────────────────────────────────────
# Stage 3d: Eclipse JDT Language Server download
# Platform-independent JAR bundle. Pulled from the always-present `latest`
# snapshot (dated milestone tarballs get pruned → 404 → empty /opt/jdtls).
# HARD-FAILS if the equinox launcher JAR or the linux config are missing after
# extraction, so a broken download can never again ship a non-functional jdtls.
# The bundles require Java 21 at runtime — see the temurin-download stage.
# ─────────────────────────────────────────────
FROM --platform=$BUILDPLATFORM debian:${DEBIAN_CODENAME}-slim AS jdtls-download

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    mkdir -p /opt/jdtls; \
    curl --fail --silent --show-error --location \
        "https://download.eclipse.org/jdtls/snapshots/jdt-language-server-latest.tar.gz" \
        -o /tmp/jdtls.tar.gz; \
    tar -xzf /tmp/jdtls.tar.gz -C /opt/jdtls; \
    rm /tmp/jdtls.tar.gz; \
    ls /opt/jdtls/plugins/org.eclipse.equinox.launcher_*.jar; \
    test -d /opt/jdtls/config_linux

# ─────────────────────────────────────────────
# Stage 3e: Temurin 21 JRE download
# The current Eclipse JDT LS bundles require Java 21 (Require-Capability
# osgi.ee=JavaSE;version=21), which Debian bookworm does not package (main ships
# 17, backports has none). Pull the Eclipse Temurin 21 JRE tarball (multi-arch
# via the Adoptium API) and copy it into the runtime; the jdtls wrapper invokes
# /opt/java21/bin/java explicitly. `test -x` (not `java -version`) so the check
# also passes under cross-platform builds where the target JRE can't exec here.
# ─────────────────────────────────────────────
FROM --platform=$BUILDPLATFORM debian:${DEBIAN_CODENAME}-slim AS temurin-download

ARG TARGETPLATFORM

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    case "${TARGETPLATFORM}" in \
        linux/amd64) JRE_ARCH="x64" ;; \
        linux/arm64) JRE_ARCH="aarch64" ;; \
        *) echo "Unsupported platform: ${TARGETPLATFORM}" && exit 1 ;; \
    esac; \
    mkdir -p /opt/java21; \
    curl --fail --silent --show-error --location \
        "https://api.adoptium.net/v3/binary/latest/21/ga/linux/${JRE_ARCH}/jre/hotspot/normal/eclipse" \
        -o /tmp/jre.tar.gz; \
    tar -xzf /tmp/jre.tar.gz -C /opt/java21 --strip-components=1; \
    rm /tmp/jre.tar.gz; \
    test -x /opt/java21/bin/java

# ─────────────────────────────────────────────
# Stage 3e: R language server build
# `languageserver` is a CRAN package whose dependency tree compiles native code
# (xml2 → libxml2, stringi → ICU). The slim runtime ships neither the compiler
# toolchain nor the -dev headers, so the previous in-runtime `install.packages`
# was best-effort and always failed: the `R` binary was detected but the package
# was absent, leaving the R LSP permanently "idle/unusable" on the dashboard.
#
# Build the package tree here against the SAME Debian r-base the runtime installs
# (identical R 4.2 ABI → the compiled .so files load unchanged) and COPY the
# resulting site-library into the runtime stage. Source-compiling stringi/xml2/
# lintr/styler takes a few minutes but is cached as its own layer.
# ─────────────────────────────────────────────
FROM debian:${DEBIAN_CODENAME}-slim AS r-lsp-build

# Parallelise across packages (Ncpus, set in the R call) and within each native
# compile (MAKEFLAGS).
ENV MAKEFLAGS="-j4"

RUN apt-get update && apt-get install -y --no-install-recommends \
        r-base \
        build-essential \
        ca-certificates \
        pkg-config \
        libxml2-dev \
        libssl-dev \
        libcurl4-openssl-dev \
        libicu-dev \
        libuv1-dev \
        zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# Compile languageserver + its dependency tree into /usr/local/lib/R/site-library.
# Unlike the old runtime attempt this HARD-FAILS the build if the package does
# not end up importable — a broken R LSP must not pass silently again.
RUN Rscript --no-save --no-restore -e "options(Ncpus = 4L); install.packages('languageserver', repos = 'https://cloud.r-project.org'); if (!nzchar(system.file(package = 'languageserver'))) { quit(status = 1) }"

# ─────────────────────────────────────────────
# Stage 4: Runtime image
# ─────────────────────────────────────────────
FROM debian:${DEBIAN_CODENAME}-slim AS runtime

ARG UID=1000

# Runtime dependencies:
#   curl  — used by the HEALTHCHECK instruction below
#   ca-certificates — needed for any TLS connections the daemon makes at runtime
#   bash           — entrypoint script uses a bash shebang and bash-only
#                    options (`set -o pipefail` / arrays).
#   nodejs / npm   — host for the npm-distributed LSPs (pyright,
#                    typescript-language-server). Pulled from the Debian
#                    archive so the arch selection is automatic.
#   git            — rust-analyzer shells out to git for some workspace
#                    detection; avoids rare "could not run git" errors at
#                    runtime.
#   python3 + python3-yaml — required by docker/memexd-entrypoint.sh for
#                    the spec 16 §9.1 stale-override check: PyYAML's
#                    safe_dump matches serde_yaml_ng byte-for-byte, used
#                    to recompute the mount-section hash inside the
#                    container before the daemon starts.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        bash \
        nodejs \
        npm \
        git \
        python3 \
        python3-yaml \
        python3-pip \
        clangd \
        r-base \
        libxml2 \
        libicu72 \
        libcurl4 \
        libssl3 \
        libuv1 \
        gcc \
        g++ \
        libc6-dev \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --gid ${UID} memexd \
    && useradd --uid ${UID} --gid ${UID} --create-home --shell /usr/sbin/nologin memexd \
    && mkdir -p \
        /home/memexd/.local/share/workspace-qdrant \
        /home/memexd/.config/workspace-qdrant \
        /home/memexd/.cache \
        /home/memexd/.local/state \
        /var/lib/wqm \
    && chown -R memexd:memexd /home/memexd \
    && chown memexd:memexd /var/lib/wqm

# libgit2 (used via the `git2` crate) runs its own ownership check on every
# Repository::open; unlike the git CLI it ignores GIT_CONFIG_* env vars and
# only reads gitconfig files. Without this, every bind-mounted host repo
# (uid 0 inside the container, opened by uid 1000 `memexd`) is rejected,
# and the watcher floods the log with "Not a Git repository, defaulting to
# 'main'" warnings. A global `[safe] directory = *` is the libgit2-honored
# equivalent of the CLI's GIT_CONFIG_VALUE_0 trick already set in compose.
RUN printf '[safe]\n\tdirectory = *\n' > /etc/gitconfig \
    && chmod 0644 /etc/gitconfig

# Install npm-based LSPs globally so the daemon can spawn them by name.
# `--omit=dev` keeps the installed tree focused on runtime artefacts.
RUN npm install --global --omit=dev \
        pyright@1.1.405 \
        typescript-language-server@4.3.4 \
        typescript@5.7.2 \
    && npm cache clean --force

# pylsp — Python LSP fallback alongside pyright.
# Uses --break-system-packages because this is a container (no system pip
# isolation needed). The [all] extra includes rope, autopep8, pyflakes, etc.
# Non-fatal: pyright already covers Python; a flaky PyPI must not break the image.
RUN pip3 install --no-cache-dir --break-system-packages \
        python-lsp-server[all]==1.12.2 \
    || echo "WARNING: pylsp install failed (non-fatal) — pyright remains the Python LSP."

# R language server — the `languageserver` package (with its compiled xml2 /
# stringi deps) is built in the dedicated `r-lsp-build` stage against the same
# Debian r-base installed above, then its site-library is copied in. The matching
# runtime shared libs (libxml2 / libicu72 / libcurl4 / libssl3) are installed in
# the apt layer above so the packages load. The daemon launches the server via
# `R --slave -e "languageserver::run()"` (see lsp/lifecycle/process.rs).
COPY --from=r-lsp-build /usr/local/lib/R/site-library /usr/local/lib/R/site-library

# Copy the native LSPs into /usr/local/bin so the daemon can spawn them by
# name. `rust-analyzer` comes from the prebuilt release archive;
# `gopls` is compiled from source in the gopls-build stage.
COPY --from=rust-analyzer-download /opt/lsp/bin/rust-analyzer /usr/local/bin/rust-analyzer
COPY --from=gopls-build /out/gopls /usr/local/bin/gopls

# Dart SDK — dart language-server --lsp handles Dart and Flutter.
COPY --from=dart-download /opt/dart-sdk /opt/dart-sdk
RUN ln -s /opt/dart-sdk/bin/dart /usr/local/bin/dart

# JDT Language Server — Java LSP via Eclipse. The current JDT bundles require
# Java 21, so ship the Temurin 21 JRE and call it explicitly from the wrapper,
# which also sets up writable -configuration / -data areas (the shipped
# config_linux is root-owned and read-only here). See docker/jdtls-wrapper.sh.
COPY --from=jdtls-download /opt/jdtls /opt/jdtls
COPY --from=temurin-download /opt/java21 /opt/java21
COPY docker/jdtls-wrapper.sh /usr/local/bin/jdtls
RUN sed -i 's/\r$//' /usr/local/bin/jdtls && chmod 0755 /usr/local/bin/jdtls

LABEL org.opencontainers.image.title="memexd" \
      org.opencontainers.image.description="workspace-qdrant-mcp Rust daemon" \
      org.opencontainers.image.version="0.1.3" \
      org.opencontainers.image.source="https://github.com/ChrisGVE/workspace-qdrant-mcp" \
      org.opencontainers.image.licenses="MIT"

COPY --from=builder /usr/local/bin/memexd /usr/local/bin/memexd
# Bundled wqm CLI — lets `docker exec wqm-memexd wqm <cmd>` run inside the daemon
# container (correct DB volume + local gRPC) so host tooling needs no local wqm.
COPY --from=builder /usr/local/bin/wqm /usr/local/bin/wqm

# Note: the Cargo release profile already sets strip=true, so the binary is
# already stripped when copied from the builder stage.  An extra `strip` pass
# would require installing binutils in the slim runtime image for no benefit.

# Spec 16 §9.1 stale-override defense — copied as root so the file is owned
# by root (mode 755), preventing the unprivileged memexd user from
# tampering with the entrypoint at runtime.
COPY docker/memexd-entrypoint.sh /usr/local/bin/memexd-entrypoint.sh
RUN sed -i 's/\r$//' /usr/local/bin/memexd-entrypoint.sh \
    && chmod 0755 /usr/local/bin/memexd-entrypoint.sh

USER memexd
ENV HOME=/home/memexd

# gRPC service port
EXPOSE 50051
# Prometheus metrics port
EXPOSE 9091

# Health check against the lightweight /health endpoint (returns HTTP 200 "OK").
# /metrics is also available but /health avoids serialising the full metrics payload.
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:9091/health || exit 1

# Flag notes (see src/rust/daemon/memexd/src/startup.rs):
#   --foreground    : mandatory in containers; prevents the daemon from forking into background
#   --grpc-port     : gRPC listen port (flag name is "grpc-port", not "port")
#   --metrics-port  : enables the Prometheus /metrics + /health HTTP endpoint
# There is no --host flag; the daemon always binds 0.0.0.0 internally.
#
# ENTRYPOINT is the wrapper script which performs the spec 16 §9.1
# three-layer mount validation, then exec's memexd with the CMD args.
# Override WQM_ENTRYPOINT_SKIP_EXEC=1 at `docker run` time to bypass the
# exec and only run validation (test/diagnostic use).
ENTRYPOINT ["/usr/local/bin/memexd-entrypoint.sh"]
CMD ["--foreground", \
     "--grpc-port", "50051", \
     "--metrics-port", "9091"]
