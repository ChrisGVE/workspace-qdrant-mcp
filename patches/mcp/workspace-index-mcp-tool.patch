diff --git a/src/typescript/mcp-server/src/tools/workspace-index.ts b/src/typescript/mcp-server/src/tools/workspace-index.ts
new file mode 100644
--- /dev/null
+++ b/src/typescript/mcp-server/src/tools/workspace-index.ts
@@ -0,0 +1,169 @@
+
+/**
+ * workspace_index MCP handler.
+ *
+ * Delegates to scripts/windows/indexed-projects-registry.ps1 and keeps a hard
+ * mutation gate. It is intentionally conservative: finishing a branch only marks
+ * it ready for review; it never merges back to the original branch.
+ */
+import { execFile } from 'node:child_process';
+import { existsSync } from 'node:fs';
+import { join, resolve } from 'node:path';
+import { promisify } from 'node:util';
+
+const execFileAsync = promisify(execFile);
+
+const MUTATING_ACTIONS = new Set([
+  'init',
+  'add_project',
+  'start_agent_branch',
+  'finish_agent_branch',
+  'abandon_agent_branch',
+  'register_wqm',
+  'register_all_wqm',
+]);
+
+const ACTION_MAP: Record<string, string> = {
+  init: 'init',
+  list_projects: 'list-projects',
+  add_project: 'add-project',
+  project_status: 'project-status',
+  status_all: 'status-all',
+  list_branches: 'list-branches',
+  start_agent_branch: 'start-agent-branch',
+  finish_agent_branch: 'finish-agent-branch',
+  abandon_agent_branch: 'abandon-agent-branch',
+  agent_branch_status: 'agent-branch-status',
+  observe_project: 'observe-project',
+  observe_all: 'observe-all',
+  incremental_check: 'incremental-check',
+  incremental_check_all: 'incremental-check-all',
+  register_wqm: 'register-wqm',
+  register_all_wqm: 'register-all-wqm',
+};
+
+function str(args: Record<string, unknown>, key: string): string | undefined {
+  const value = args[key];
+  return typeof value === 'string' && value.length > 0 ? value : undefined;
+}
+
+function boolString(value: unknown, defaultValue = false): string {
+  if (typeof value === 'boolean') return value ? 'true' : 'false';
+  if (typeof value === 'string') return /^(1|true|yes|y)$/i.test(value) ? 'true' : 'false';
+  return defaultValue ? 'true' : 'false';
+}
+
+function resolveScriptPath(): string {
+  const explicit = process.env['WQM_WORKSPACE_INDEX_SCRIPT'];
+  if (explicit) return resolve(explicit);
+  const repoDir = process.env['WQM_REPO_DIR'] ?? process.cwd();
+  return resolve(repoDir, 'scripts', 'windows', 'indexed-projects-registry.ps1');
+}
+
+function mutationAllowed(args: Record<string, unknown>): boolean {
+  return (
+    boolString(args['allowMutation']) === 'true' &&
+    /^(1|true|yes|y)$/i.test(process.env['WQM_INDEX_MANAGER_ALLOW_MUTATION'] ?? '')
+  );
+}
+
+export async function handleWorkspaceIndex(
+  rawArgs: Record<string, unknown> | undefined
+): Promise<unknown> {
+  const args = rawArgs ?? {};
+  const action = str(args, 'action');
+  if (!action || !(action in ACTION_MAP)) {
+    return { success: false, error: `Unknown or missing workspace_index action: ${String(action)}` };
+  }
+
+  const isMutation = MUTATING_ACTIONS.has(action);
+  const allowMutation = mutationAllowed(args);
+  if (isMutation && !allowMutation) {
+    return {
+      success: false,
+      action,
+      error:
+        'Mutation blocked. Set allowMutation=true in the tool call and WQM_INDEX_MANAGER_ALLOW_MUTATION=1 in the MCP environment.',
+    };
+  }
+
+  const script = resolveScriptPath();
+  if (!existsSync(script)) {
+    return { success: false, action, error: `workspace_index script not found: ${script}` };
+  }
+
+  const ps = process.env['WQM_POWERSHELL'] ?? (process.platform === 'win32' ? 'powershell.exe' : 'pwsh');
+  const registry =
+    str(args, 'registryPath') ??
+    process.env['WQM_INDEX_REGISTRY'] ??
+    join(process.cwd(), '.wqm-fork', 'indexed-projects.json');
+
+  const psArgs = [
+    '-NoProfile',
+    '-ExecutionPolicy',
+    'Bypass',
+    '-File',
+    script,
+    '-Action',
+    ACTION_MAP[action],
+    '-RegistryPath',
+    registry,
+    '-Json',
+    'true',
+    '-Mutate',
+    allowMutation ? 'true' : 'false',
+  ];
+
+  const mappings: Array<[string, string]> = [
+    ['projectName', 'ProjectName'],
+    ['projectDir', 'ProjectDir'],
+    ['branchName', 'BranchName'],
+    ['baseBranch', 'BaseBranch'],
+    ['returnBranch', 'ReturnBranch'],
+    ['worktreePath', 'WorktreePath'],
+    ['worktreeRoot', 'WorktreeRoot'],
+    ['purpose', 'Purpose'],
+    ['createdBy', 'CreatedBy'],
+  ];
+  for (const [from, to] of mappings) {
+    const value = str(args, from);
+    if (value) psArgs.push(`-${to}`, value);
+  }
+  psArgs.push('-UseWorktree', boolString(args['useWorktree'], true));
+
+  try {
+    const { stdout, stderr } = await execFileAsync(ps, psArgs, {
+      timeout: Number(process.env['WQM_INDEX_MANAGER_TIMEOUT_MS'] ?? 120_000),
+      maxBuffer: 2 * 1024 * 1024,
+    });
+    const trimmed = stdout.trim();
+    if (!trimmed) return { success: true, action, stderr: stderr.trim() };
+    try {
+      return JSON.parse(trimmed);
+    } catch {
+      return { success: true, action, output: trimmed, stderr: stderr.trim() };
+    }
+  } catch (error: unknown) {
+    const e = error as { message?: string; stdout?: string; stderr?: string; code?: number };
+    return {
+      success: false,
+      action,
+      error: e.message ?? String(error),
+      exitCode: e.code,
+      stdout: e.stdout,
+      stderr: e.stderr,
+    };
+  }
+}
