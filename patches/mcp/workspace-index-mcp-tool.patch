@@ -0,0 +1,162 @@
+/**
+ * workspace_index MCP tool implementation.
+ *
+ * The actual registry/worktree logic lives in the Windows PowerShell helper
+ * scripts shipped by the fork kit. This TypeScript layer only:
+ * - validates the double opt-in required for mutating actions;
+ * - finds the repo-local PowerShell bridge;
+ * - executes it and returns structured JSON to the MCP client.
+ */
+
+import { spawn } from 'node:child_process';
+import { existsSync } from 'node:fs';
+import { resolve } from 'node:path';
+
+const MUTATING_ACTIONS = new Set([
+  'init',
+  'add_project',
+  'start_agent_branch',
+  'finish_agent_branch',
+  'abandon_agent_branch',
+  'register_wqm',
+  'register_all_wqm',
+]);
+
+type JsonObject = Record<string, unknown>;
+
+function asObject(value: Record<string, unknown> | undefined): JsonObject {
+  return value ?? {};
+}
+
+function stringArg(args: JsonObject, key: string): string | undefined {
+  const value = args[key];
+  return typeof value === 'string' && value.trim().length > 0 ? value : undefined;
+}
+
+function isMutation(action: string): boolean {
+  return MUTATING_ACTIONS.has(action);
+}
+
+function assertMutationAllowed(action: string, args: JsonObject): void {
+  if (!isMutation(action)) return;
+
+  const envAllowed = process.env['WQM_INDEX_MANAGER_ALLOW_MUTATION'] === '1';
+  const callAllowed = args['allowMutation'] === true;
+  if (!envAllowed || !callAllowed) {
+    throw new Error(
+      `workspace_index action '${action}' is mutating and requires both ` +
+        'WQM_INDEX_MANAGER_ALLOW_MUTATION=1 and allowMutation=true.'
+    );
+  }
+}
+
+function resolveRepoDir(args: JsonObject): string {
+  return (
+    stringArg(args, 'repoDir') ??
+    process.env['WQM_REPO_DIR'] ??
+    process.cwd()
+  );
+}
+
+function resolveBridgeScript(repoDir: string): string {
+  return resolve(repoDir, 'scripts', 'windows', 'workspace-index-mcp.ps1');
+}
+
+function resolvePowerShellCommand(): string {
+  return process.platform === 'win32' ? 'powershell.exe' : 'pwsh';
+}
+
+function parseToolOutput(stdout: string, stderr: string): unknown {
+  const trimmed = stdout.trim();
+  if (trimmed.length === 0) {
+    return {
+      success: true,
+      message: 'workspace_index command completed with no stdout.',
+      stderr: stderr.trim() || undefined,
+    };
+  }
+
+  try {
+    return JSON.parse(trimmed);
+  } catch {
+    return {
+      success: true,
+      raw: trimmed,
+      stderr: stderr.trim() || undefined,
+    };
+  }
+}
+
+function runPowerShellBridge(
+  scriptPath: string,
+  repoDir: string,
+  payload: JsonObject
+): Promise<unknown> {
+  const command = resolvePowerShellCommand();
+  const inputJson = JSON.stringify(payload);
+
+  const childArgs = [
+    '-NoProfile',
+    '-ExecutionPolicy',
+    'Bypass',
+    '-File',
+    scriptPath,
+    '-RepoDir',
+    repoDir,
+    '-InputJson',
+    inputJson,
+  ];
+
+  return new Promise((resolvePromise, reject) => {
+    const child = spawn(command, childArgs, {
+      cwd: repoDir,
+      windowsHide: true,
+      env: {
+        ...process.env,
+        WQM_WORKSPACE_INDEX_ARGS_JSON: inputJson,
+      },
+    });
+
+    let stdout = '';
+    let stderr = '';
+
+    child.stdout.setEncoding('utf8');
+    child.stderr.setEncoding('utf8');
+
+    child.stdout.on('data', (chunk: string) => {
+      stdout += chunk;
+    });
+    child.stderr.on('data', (chunk: string) => {
+      stderr += chunk;
+    });
+
+    child.on('error', (error) => {
+      reject(error);
+    });
+
+    child.on('close', (code) => {
+      if (code !== 0) {
+        reject(
+          new Error(
+            `workspace_index PowerShell bridge failed with code ${code}. ` +
+              `stderr: ${stderr.trim() || '(empty)'}`
+          )
+        );
+        return;
+      }
+      resolvePromise(parseToolOutput(stdout, stderr));
+    });
+  });
+}
+
+export async function handleWorkspaceIndex(
+  rawArgs: Record<string, unknown> | undefined
+): Promise<unknown> {
+  const args = asObject(rawArgs);
+  const action = stringArg(args, 'action');
+  if (!action) {
+    throw new Error('workspace_index requires an action.');
+  }
+
+  assertMutationAllowed(action, args);
+
+  const repoDir = resolveRepoDir(args);
+  const scriptPath = resolveBridgeScript(repoDir);
+  if (!existsSync(scriptPath)) {
+    throw new Error(
+      `workspace_index bridge script not found at ${scriptPath}. ` +
+        'Apply the fork kit overlay before enabling this MCP tool.'
+    );
+  }
+
+  return runPowerShellBridge(scriptPath, repoDir, { ...args, action, repoDir });
+}
