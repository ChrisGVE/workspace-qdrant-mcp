+      registryPath: { type: 'string', description: 'Path to .wqm-fork/indexed-projects.json. Defaults to env/default.' },
+      allowMutation: { type: 'boolean', description: 'Required for mutating actions, together with WQM_INDEX_MANAGER_ALLOW_MUTATION=1.' },
+    },
+    required: ['action'],
+  },
+};
