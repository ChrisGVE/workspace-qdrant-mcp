+/**
+ * MCP tool schema definition for the local fork workspace manager.
+ *
+ * This tool is intended for personal forks only. It is read-only by default;
+ * mutations require both allowMutation=true and WQM_WORKSPACE_MANAGER_ALLOW_MUTATION=1.
+ */
+export const forkWorkspaceToolDefinition = {
+  name: 'fork_workspace',
+  description:
+    'Manage the local fork workspace registry and safe branch chains across multiple projects. Read-only by default. Mutating actions require allowMutation=true and WQM_WORKSPACE_MANAGER_ALLOW_MUTATION=1. This tool never opens PRs and never merges into main.',
+  inputSchema: {
+    type: 'object' as const,
+    properties: {
+      action: {
+        type: 'string',
+        enum: [
+          'registry:list',
+          'registry:add',
+          'registry:remove',
+          'project:status',
+          'projects:status',
+          'project:sync-chain',
+          'projects:sync-chain',
+          'project:start-fix',
+          'project:promote-fix',
+        ],
+        description: 'Workspace-management action to execute.',
+      },
+      name: {
+        type: 'string',
+        description: 'Registry project name.',
+      },
+      path: {
+        type: 'string',
+        description: 'Project repository path, used for registry:add or direct project selection.',
+      },
+      fixBranch: {
+        type: 'string',
+        description: 'Correction branch such as fix/rules-tenant-scope.',
+      },
+      registryPath: {
+        type: 'string',
+        description:
+          'Optional registry JSON path. Defaults to WQM_WORKSPACE_REGISTRY_PATH or .wqm-fork/projects.json under the server cwd.',
+      },
+      push: {
+        type: 'boolean',
+        description: 'Push updated non-main branches to origin after mutating operations. Default: false.',
+      },
+      allowMutation: {
+        type: 'boolean',
+        description:
+          'Required for mutating operations. The environment variable WQM_WORKSPACE_MANAGER_ALLOW_MUTATION must also be 1/true.',
+      },
+    },
+    required: ['action'],
+  },
+};
